<style>
:root{
  --bg:#1e1e1e; --bg-2:#181818; --panel:#252526; --panel-2:#2d2d30; --border:#3c3c3c;
  --text:#d4d4d4; --text-dim:#9d9d9d; --text-faint:#6a6a6a;
