<script>
(() => {
'use strict';

/* =========================================================================
   0. ERROR SYSTEM
   ========================================================================= */
class LullangError extends Error {
  constructor(type, message, line, suggestion) {
    super(message);
    this.errType = type; this.line = line !== undefined ? line : '?'; this.suggestion = suggestion || '문법과 들여쓰기를 확인하세요.';
  }
}
const problems = [];
function pushProblem(severity, type, message, line, suggestion) {
  problems.push({ severity, type, message, line: line !== undefined ? line : '?', suggestion: suggestion || '문법과 들여쓰기를 확인하세요.' });
  renderProblems();
}
function clearProblems() { problems.length = 0; renderProblems(); }

const consoleLines = [];
function consoleLog(kind, text) {
  consoleLines.push({ kind, text, t: new Date().toLocaleTimeString() });
  if (consoleLines.length > 300) consoleLines.shift();
  renderConsole();
}

/* =========================================================================
   1. RAM
   ========================================================================= */
const RAM_SIZE = 256;
const RAM = new Array(RAM_SIZE).fill(0);

/* =========================================================================
   2. TOKENIZER (expressions)
   ========================================================================= */
class LullangTokenizer {
  constructor(src) { this.src = src; }
  isDigit(c) { return c >= '0' && c <= '9'; }
  isIdentStart(c) { return /[A-Za-z_가-힣]/.test(c); }
  isIdentPart(c) { return /[A-Za-z0-9_가-힣]/.test(c); }
  tokenize() {
    const s = this.src;
    let i = 0;
    const tokens = [];
    while (i < s.length) {
      const c = s[i];
      if (c === ' ' || c === '\t') { i++; continue; }
      if (this.isDigit(c) || (c === '.' && this.isDigit(s[i + 1]))) {
        let j = i; while (j < s.length && (this.isDigit(s[j]) || s[j] === '.')) j++;
        tokens.push({ type: 'NUMBER', value: parseFloat(s.slice(i, j)) });
        i = j; continue;
      }
      if (this.isIdentStart(c)) {
        let j = i; while (j < s.length && this.isIdentPart(s[j])) j++;
        tokens.push({ type: 'IDENT', value: s.slice(i, j) });
        i = j; continue;
      }
      if (c === '#') {
        let j = i + 1; while (j < s.length && /[0-9a-fA-F]/.test(s[j])) j++;
        tokens.push({ type: 'STRING', value: s.slice(i, j) });
        i = j; continue;
      }
      if (c === '"') {
        let j = i + 1; while (j < s.length && s[j] !== '"') j++;
        tokens.push({ type: 'STRING', value: s.slice(i + 1, j) });
        i = j + 1; continue;
      }
      const two = s.slice(i, i + 2);
      if (['==', '!=', '>=', '<=', '&&', '||'].includes(two)) { tokens.push({ type: 'OP', value: two }); i += 2; continue; }
      if ('+-*/%()[]!<>,{}='.includes(c)) { tokens.push({ type: 'OP', value: c }); i++; continue; }
      i++;
    }
    tokens.push({ type: 'EOF', value: null });
    return tokens;
  }
}

/* =========================================================================
   3. EXPRESSION PARSER -> AST  (recursive descent, no eval/new Function)
   ========================================================================= */
class LullangExprParser {
  constructor(tokens) { this.tokens = tokens; this.pos = 0; }
  peek() { return this.tokens[this.pos]; }
  next() { return this.tokens[this.pos++]; }
  expect(value) {
    const t = this.next();
    if (t.value !== value) throw new LullangError('SYNTAX', '"' + value + '" 를 예상했지만 "' + t.value + '" 를 발견함', 0, '식 문법을 확인하세요: ' + value + ' 위치');
    return t;
  }
  parseExpression() { return this.parseLogicOr(); }
  parseLogicOr() { let n = this.parseLogicAnd(); while (this.peek().value === '||') { this.next(); n = { type: 'logic', op: '||', left: n, right: this.parseLogicAnd() }; } return n; }
  parseLogicAnd() { let n = this.parseEquality(); while (this.peek().value === '&&') { this.next(); n = { type: 'logic', op: '&&', left: n, right: this.parseEquality() }; } return n; }
  parseEquality() { let n = this.parseComparison(); while (['==', '!='].includes(this.peek().value)) { const op = this.next().value; n = { type: 'binop', op, left: n, right: this.parseComparison() }; } return n; }
  parseComparison() { let n = this.parseAdditive(); while (['>', '<', '>=', '<='].includes(this.peek().value)) { const op = this.next().value; n = { type: 'binop', op, left: n, right: this.parseAdditive() }; } return n; }
  parseAdditive() { let n = this.parseMultiplicative(); while (['+', '-'].includes(this.peek().value)) { const op = this.next().value; n = { type: 'binop', op, left: n, right: this.parseMultiplicative() }; } return n; }
  parseMultiplicative() { let n = this.parseUnary(); while (['*', '/', '%'].includes(this.peek().value)) { const op = this.next().value; n = { type: 'binop', op, left: n, right: this.parseUnary() }; } return n; }
  parseUnary() { if (this.peek().value === '!' || this.peek().value === '-') { const op = this.next().value; return { type: 'unop', op, expr: this.parseUnary() }; } return this.parsePrimary(); }
  parsePrimary() {
    const t = this.peek();
    if (t.type === 'NUMBER') { this.next(); return { type: 'num', value: t.value }; }
    if (t.value === '(') { this.next(); const e = this.parseExpression(); this.expect(')'); return e; }
    if (t.type === 'IDENT' && t.value === 'RAM') { this.next(); this.expect('['); const idx = this.parseExpression(); this.expect(']'); return { type: 'ram', index: idx }; }
    if (t.type === 'IDENT' && t.value === 'ISCOLLIDE') { this.next(); this.expect('('); const a = this.parseExpression(); this.expect(','); const b = this.parseExpression(); this.expect(')'); return { type: 'iscollide', a, b }; }
    if (t.type === 'IDENT') { this.next(); return { type: 'ident', name: t.value }; }
    if (t.type === 'STRING') { this.next(); return { type: 'str', value: t.value }; }
    throw new LullangError('SYNTAX', '예상치 못한 토큰 "' + t.value + '"', 0, '식(expression) 문법을 확인하세요');
  }
}
function parseLullangExpression(src) {
  const tokens = new LullangTokenizer(src).tokenize();
  return new LullangExprParser(tokens).parseExpression();
}

/* =========================================================================
   4. OBJECT MANAGER
   ========================================================================= */
class LullangObjectManagerClass {
  constructor() { this.objects = new Map(); }
  createOrUpdate(id, type, x, y, w, h, color) {
    if (this.objects.has(id)) {
      const o = this.objects.get(id);
      o.type = type; o.x = x; o.y = y; o.width = w; o.height = h; o.size = Math.max(w, h);
      if (color) o.color = color;
      return o;
    }
    const o = {
      id, type, x, y, width: w, height: h, size: Math.max(w, h), color: color || '#4da3ff',
      visible: true, sprite: null, layer: 0, angle: 0, scale: 1, active: true, _fromTile: false
    };
    this.objects.set(id, o);
    return o;
  }
  setProperty(id, prop, value) {
    const o = this.objects.get(id);
    if (!o) { pushProblem('warning', 'RUNTIME', '존재하지 않는 오브젝트에 SET 시도: ' + id, '?', 'OBJECT 문으로 먼저 생성하세요.'); return false; }
    const key = prop.toLowerCase();
    if (key === 'x') o.x = value; else if (key === 'y') o.y = value;
    else if (key === 'width') o.width = value; else if (key === 'height') o.height = value;
    else if (key === 'size') { o.size = value; o.width = value; o.height = value; }
    else if (key === 'color') o.color = value; else if (key === 'visible') o.visible = !!value;
    else if (key === 'sprite') o.sprite = value; else if (key === 'layer') o.layer = value;
    else if (key === 'angle') o.angle = value; else if (key === 'scale') o.scale = value;
    else if (key === 'active') o.active = !!value;
    else { pushProblem('warning', 'RUNTIME', '알 수 없는 프로퍼티: ' + prop, '?', 'X/Y/WIDTH/HEIGHT/SIZE/COLOR/VISIBLE/SPRITE/LAYER/ANGLE/SCALE/ACTIVE 중 하나를 사용하세요.'); return false; }
    return true;
  }
  get(id) { return this.objects.get(id) || null; }
  getAllByType(type) { return [...this.objects.values()].filter(o => o.type === type); }
  all() { return [...this.objects.values()]; }
  clearAll() { this.objects.clear(); }
}
const LullangObjectManager = new LullangObjectManagerClass();

/* =========================================================================
   5. SPRITE MANAGER
   ========================================================================= */
const LULLANG_PALETTE = { '.': null, '0': '#000000', '1': '#ffffff', '2': '#f2585a', '3': '#5fd097', '4': '#4da3ff', '5': '#e8b84b', '6': '#c586c0', '7': '#f2884b' };
class LullangSpriteManagerClass {
  constructor() { this.sprites = new Map(); }
  register(name, rows) { this.sprites.set(name, rows); }
  get(name) { return this.sprites.get(name) || null; }
  count() { return this.sprites.size; }
  draw(ctx, name, x, y, cellSize) {
    const rows = this.get(name);
    if (!rows) return false;
    const cs = cellSize || 4;
    for (let ry = 0; ry < rows.length; ry++) {
      const row = rows[ry];
      for (let rx = 0; rx < row.length; rx++) {
        const color = LULLANG_PALETTE[row[rx]];
        if (!color) continue;
        ctx.fillStyle = color;
        ctx.fillRect(x + rx * cs, y + ry * cs, cs, cs);
      }
    }
    return true;
  }
}
const LullangSpriteManager = new LullangSpriteManagerClass();

/* =========================================================================
   6. TILE MANAGER
   ========================================================================= */
class LullangTileManagerClass {
  constructor() { this.rows = []; this.tileSize = 20; }
  loadMap(rows) {
    LullangObjectManager.all().filter(o => o._fromTile).forEach(o => LullangObjectManager.objects.delete(o.id));
    this.rows = rows;
    for (let ry = 0; ry < rows.length; ry++) {
      const row = rows[ry];
      for (let rx = 0; rx < row.length; rx++) {
        const ch = row[rx];
        const px = rx * this.tileSize, py = ry * this.tileSize;
        if (ch === '#') {
          const o = LullangObjectManager.createOrUpdate('tile_wall_' + rx + '_' + ry, 'WALL', px, py, this.tileSize, this.tileSize, '#3c3c3c');
          o._fromTile = true;
        } else if (ch === 'P') {
          LullangObjectManager.createOrUpdate('player', 'PLAYER', px, py, this.tileSize - 2, this.tileSize - 2, '#5fd097');
        }
      }
    }
  }
  tileCountSolid() { return this.rows.join('').split('').filter(c => c === '#').length; }
  render(ctx, camera) {
    for (let ry = 0; ry < this.rows.length; ry++) {
      const row = this.rows[ry];
      for (let rx = 0; rx < row.length; rx++) {
        if (row[rx] !== '#') continue;
        ctx.fillStyle = '#2d2d30';
        ctx.fillRect(rx * this.tileSize - camera.x, ry * this.tileSize - camera.y, this.tileSize, this.tileSize);
      }
    }
  }
}
