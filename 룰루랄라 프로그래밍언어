const editorHighlight = document.getElementById('codeHighlight');
const lineGutter = document.getElementById('lineGutter');

function escapeHtml(s) { return s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;'); }
function highlightLullang(src) {
  let html = escapeHtml(src);
  html = html.replace(/(\/\/.*)$/gm, '<span class="tok-comment">$1</span>');
  html = html.replace(/"([^"]*)"/g, '<span class="tok-string">"$1"</span>');
  html = html.replace(/#[0-9a-fA-F]{3,6}\b/g, m => '<span class="tok-color">' + m + '</span>');
  html = html.replace(/\b(\d+(\.\d+)?)\b/g, '<span class="tok-number">$1</span>');
  html = html.replace(/(룰랄|아니면|루루|FUNCTION|END|CALL|SPRITE|OBJECT|WALL|SET|RAM|CLEAR|RENDER|TEXT|MAP|ENDMAP|TOUCH|CAMERA|ISCOLLIDE|COLLIDE|FOLLOW|ZOOM)/g, '<span class="tok-keyword">$1</span>');
  html = html.replace(/\b(PLAYER|NPC|ENEMY|PROJECTILE|ITEM|CUSTOM)\b/g, '<span class="tok-type">$1</span>');
  return html;
}
function updateLineGutter(text) {
  const n = text.split('\n').length;
  let out = '';
  for (let i = 1; i <= n; i++) out += i + '\n';
  lineGutter.textContent = out;
}
function refreshEditorView() {
  const val = editorInput.value;
  editorHighlight.innerHTML = highlightLullang(val) + '\n';
  updateLineGutter(val);
}
editorInput.addEventListener('input', () => { refreshEditorView(); LullangFS.save(editorInput.value); });
editorInput.addEventListener('scroll', () => {
  editorHighlight.scrollTop = editorInput.scrollTop; editorHighlight.scrollLeft = editorInput.scrollLeft;
  lineGutter.scrollTop = editorInput.scrollTop;
});
editorInput.addEventListener('keydown', (e) => {
  if (e.key === 'Tab') {
    e.preventDefault();
    const start = editorInput.selectionStart, end = editorInput.selectionEnd;
    editorInput.value = editorInput.value.slice(0, start) + '  ' + editorInput.value.slice(end);
    editorInput.selectionStart = editorInput.selectionEnd = start + 2;
    refreshEditorView(); LullangFS.save(editorInput.value);
  } else if (e.key === 'Enter') {
    e.preventDefault();
    const start = editorInput.selectionStart;
    const value = editorInput.value;
    const lineStart = value.lastIndexOf('\n', start - 1) + 1;
    const currentLine = value.slice(lineStart, start);
    const indentMatch = currentLine.match(/^\s*/);
    let indent = indentMatch ? indentMatch[0] : '';
    if (currentLine.trim().endsWith('{')) indent += '  ';
    const insertion = '\n' + indent;
    editorInput.value = value.slice(0, start) + insertion + value.slice(start);
    editorInput.selectionStart = editorInput.selectionEnd = start + insertion.length;
    refreshEditorView(); LullangFS.save(editorInput.value);
  }
});

function loadFileIntoEditor(name) {
  LullangFS.setActive(name);
  editorInput.value = LullangFS.getActive();
  refreshEditorView();
  document.getElementById('editorFileBadge').textContent = name;
  document.getElementById('topActiveFile').textContent = name;
  renderExplorer();
}

/* =========================================================================
   15. EXPLORER UI
   ========================================================================= */
const explorerListEl = document.getElementById('explorerList');
function renderExplorer() {
  explorerListEl.innerHTML = '';
  LullangFS.order.forEach(name => {
    const row = document.createElement('div');
    row.className = 'file-item' + (name === LullangFS.activeFile ? ' active' : '');
    row.innerHTML = '<span class="file-icon">▤</span><span>' + name + '</span>';
    row.addEventListener('click', () => loadFileIntoEditor(name));
    explorerListEl.appendChild(row);
  });
  document.getElementById('fileCountBadge').textContent = LullangFS.order.length + ' files';
}
document.getElementById('newFileBtn').addEventListener('click', () => {
  const name = prompt('새 파일 이름 (예: boss.lul)');
  if (!name) return;
  const finalName = name.endsWith('.lul') ? name : name + '.lul';
  if (LullangFS.files[finalName] !== undefined) { alert('이미 존재하는 파일입니다.'); return; }
  LullangFS.files[finalName] = '// 새 파일\n';
  LullangFS.order.push(finalName);
  loadFileIntoEditor(finalName);
});

/* =========================================================================
   16. ANALYZER PANEL (tokens / AST / problems / console)
   ========================================================================= */
document.querySelectorAll('.analyzer-tab').forEach(btn => {
  btn.addEventListener('click', () => {
    document.querySelectorAll('.analyzer-tab').forEach(b => b.classList.remove('active'));
    document.querySelectorAll('.an-view').forEach(v => v.classList.remove('active'));
    btn.classList.add('active');
    document.getElementById('view-' + btn.dataset.tab).classList.add('active');
  });
});
function renderConsole() {
  const el = document.getElementById('view-console');
  if (!consoleLines.length) { el.innerHTML = '<div class="an-empty">콘솔 출력이 여기에 표시됩니다.</div>'; return; }
  el.innerHTML = consoleLines.map(c => '<div class="console-row ' + c.kind + '">[' + c.t + '] ' + escapeHtml(c.text) + '</div>').join('');
  el.scrollTop = el.scrollHeight;
}
function renderTokensView(sourceText) {
  try {
    const exprLines = sourceText.split('\n').filter(l => /[=<>!]|RAM\[|ISCOLLIDE/.test(l));
    const dump = exprLines.slice(0, 40).map(l => {
      const tokens = new LullangTokenizer(l).tokenize().filter(t => t.type !== 'EOF');
      return l.trim() + '\n  -> ' + tokens.map(t => t.type + ':' + t.value).join(' | ');
    }).join('\n\n');
    document.getElementById('tokenView').textContent = dump || '(표시할 표현식이 없습니다)';
  } catch (e) { document.getElementById('tokenView').textContent = '토큰화 실패: ' + e.message; }
}
function renderAstView(program) {
  document.getElementById('astView').textContent = JSON.stringify(program, null, 2);
}
function renderProblems() {
  const el = document.getElementById('view-problems');
  document.getElementById('problemCountBadge').textContent = problems.length + ' problems';
  if (!problems.length) { el.innerHTML = '<div class="an-empty" id="problemsEmpty">오류/경고 없음</div>'; return; }
  el.innerHTML = problems.map(p =>
    '<div class="problem-row ' + (p.severity === 'warning' ? 'warning' : '') + '">' +
    '<div class="p-head">[' + p.severity.toUpperCase() + ' · ' + p.type + '] Line ' + p.line + ': ' + escapeHtml(p.message) + '</div>' +
    '<div class="p-suggest">💡 ' + escapeHtml(p.suggestion) + '</div></div>'
  ).join('');
}

/* =========================================================================
   17. OBJECT MANAGER PANEL (live list) + RUN / STOP / RESTART
   ========================================================================= */
const objectListBody = document.getElementById('objectListBody');
function renderObjectList() {
  const objs = LullangObjectManager.all();
  document.getElementById('objCountBadge').textContent = objs.length;
  if (!objs.length) { objectListBody.innerHTML = '<div class="obj-empty">오브젝트가 없습니다.</div>'; return; }
  objectListBody.innerHTML = objs.map(o =>
    '<div class="obj-row"><span class="obj-id">' + o.id + '</span><span class="obj-type">' + o.type + '</span><span>(' + Math.round(o.x) + ',' + Math.round(o.y) + ')</span></div>'
  ).join('');
}

const lullangCanvasEl = document.getElementById('lullangCanvas');
const LullangRenderer = new LullangRendererClass(lullangCanvasEl);
LullangInput.bindCanvas(lullangCanvasEl);

let lullangRunning = false;
let lullangFrameCount = 0, lullangFpsLastSample = performance.now(), lullangFps = 0;
const fpsBadgeEl = document.getElementById('fpsBadge');
const runStatusEl = document.getElementById('topRunStatus');

function lullangGameLoop(now) {
  if (!lullangRunning) return;
  lullangFrameCount++;
  if (now - lullangFpsLastSample >= 500) {
    lullangFps = Math.round(lullangFrameCount / ((now - lullangFpsLastSample) / 1000));
    lullangFrameCount = 0; lullangFpsLastSample = now;
    fpsBadgeEl.textContent = lullangFps + ' FPS';
  }
  LullangInput.syncToRam();
  LullangCamera.update(lullangCanvasEl.width, lullangCanvasEl.height);
  try {
    LullangInterpreter.runFrame();
  } catch (err) {
    lullangRunning = false;
    runStatusEl.textContent = 'error';
    const e = err instanceof LullangError ? err : new LullangError('RUNTIME', err.message, '?', '런타임 오류입니다. Problems 탭을 확인하세요.');
    pushProblem('error', e.errType, e.message, e.line, e.suggestion);
    consoleLog('err', '실행 중단: ' + e.message);
    return;
  }
  renderObjectList();
  requestAnimationFrame(lullangGameLoop);
}

function compileActiveFile() {
  clearProblems();
  const source = editorInput.value;
  try {
    const program = LullangInterpreter.compile(source);
    renderAstView(program);
    renderTokensView(source);
    consoleLog('info', LullangFS.activeFile + ' 컴파일 성공 (' + program.length + '개 최상위 구문)');
    return true;
  } catch (err) {
    const e = err instanceof LullangError ? err : new LullangError('COMPILE', err.message, '?', '문법을 다시 확인하세요.');
    pushProblem('error', e.errType, e.message, e.line, e.suggestion);
    consoleLog('err', '컴파일 실패: ' + e.message);
    return false;
  }
}

document.getElementById('runBtn2').addEventListener('click', () => {
  if (lullangRunning) return;
  if (!compileActiveFile()) { runStatusEl.textContent = 'compile error'; return; }
  lullangRunning = true;
  runStatusEl.textContent = 'running';
  consoleLog('info', 'RUN — ' + LullangFS.activeFile);
  requestAnimationFrame(lullangGameLoop);
});
document.getElementById('stopBtn2').addEventListener('click', () => {
  lullangRunning = false;
  runStatusEl.textContent = 'stopped';
  consoleLog('info', 'STOP');
});
document.getElementById('restartBtn2').addEventListener('click', () => {
  lullangRunning = false;
  LullangObjectManager.clearAll();
  for (let i = 0; i < RAM_SIZE; i++) RAM[i] = 0;
  LullangCamera.x = 0; LullangCamera.y = 0; LullangCamera.zoom = 1; LullangCamera.followId = null;
  LullangTileManager.rows = [];
  clearProblems();
  consoleLog('info', 'RESTART — 상태 초기화 완료');
  renderObjectList();
  if (!compileActiveFile()) { runStatusEl.textContent = 'compile error'; return; }
  lullangRunning = true;
  runStatusEl.textContent = 'running';
  requestAnimationFrame(lullangGameLoop);
});

/* =========================================================================
   18. BOOT
   ========================================================================= */
renderExplorer();
loadFileIntoEditor('main.lul');
renderConsole();
renderProblems();
consoleLog('info', 'Lullang IDE v4.0 초기화 완료. RUN을 눌러 main.lul을 실행하세요.');
})();
</script>
</body>
</html>
