/* =========================================================================
   7. COLLISION MANAGER
   ========================================================================= */
class LullangCollisionManagerClass {
  aabbOverlap(a, b) { return a.x < b.x + b.width && a.x + a.width > b.x && a.y < b.y + b.height && a.y + a.height > b.y; }
  isCollidingById(idA, idB) {
    const a = LullangObjectManager.get(idA), b = LullangObjectManager.get(idB);
    if (!a || !b || !a.active || !b.active) return false;
    return this.aabbOverlap(a, b);
  }
  anyCollidingByType(typeA, typeB) {
    const as = LullangObjectManager.getAllByType(typeA), bs = LullangObjectManager.getAllByType(typeB);
    for (const a of as) for (const b of bs) { if (a === b) continue; if (a.active && b.active && this.aabbOverlap(a, b)) return true; }
    return false;
  }
}
const LullangCollision = new LullangCollisionManagerClass();

/* =========================================================================
   8. CAMERA
   ========================================================================= */
class LullangCameraClass {
  constructor() { this.x = 0; this.y = 0; this.zoom = 1; this.followId = null; }
  follow(id) { this.followId = id; }
  update(canvasW, canvasH) {
    if (this.followId) {
      const o = LullangObjectManager.get(this.followId);
      if (o) { this.x = o.x - canvasW / (2 * this.zoom); this.y = o.y - canvasH / (2 * this.zoom); }
    }
  }
}
const LullangCamera = new LullangCameraClass();

/* =========================================================================
   9. INPUT MANAGER
   ========================================================================= */
class LullangInputManagerClass {
  constructor() {
    this.keys = new Set(); this.mouseX = 0; this.mouseY = 0; this.mouseDown = false;
    window.addEventListener('keydown', e => { this.keys.add(e.key.toLowerCase()); });
    window.addEventListener('keyup', e => this.keys.delete(e.key.toLowerCase()));
  }
  bindCanvas(canvas) {
    canvas.addEventListener('mousemove', e => { const r = canvas.getBoundingClientRect(); this.mouseX = e.clientX - r.left; this.mouseY = e.clientY - r.top; });
    canvas.addEventListener('mousedown', () => this.mouseDown = true);
    canvas.addEventListener('mouseup', () => this.mouseDown = false);
  }
  syncToRam() {
    RAM[240] = this.keys.has('w') ? 1 : 0;
    RAM[241] = this.keys.has('a') ? 1 : 0;
    RAM[242] = this.keys.has('s') ? 1 : 0;
    RAM[243] = this.keys.has('d') ? 1 : 0;
    RAM[244] = this.keys.has('arrowup') ? 1 : 0;
    RAM[245] = this.keys.has('arrowdown') ? 1 : 0;
    RAM[246] = this.keys.has('arrowleft') ? 1 : 0;
    RAM[247] = this.keys.has('arrowright') ? 1 : 0;
    RAM[248] = this.mouseDown ? 1 : 0;
    RAM[249] = Math.round(this.mouseX);
    RAM[250] = Math.round(this.mouseY);
  }
  pressedKeysList() { return [...this.keys].join(', ') || '(none)'; }
}
const LullangInput = new LullangInputManagerClass();

/* =========================================================================
   10. RENDERER
   ========================================================================= */
class LullangRendererClass {
  constructor(canvas) { this.canvas = canvas; this.ctx = canvas.getContext('2d'); this.textQueue = []; }
  clear() { this.textQueue = []; this.ctx.fillStyle = '#0b0b0d'; this.ctx.fillRect(0, 0, this.canvas.width, this.canvas.height); }
  pushText(x, y, text) { this.textQueue.push({ x, y, text }); }
  flush() {
    LullangTileManager.render(this.ctx, LullangCamera);
    const objs = LullangObjectManager.all().filter(o => o.visible && o.active).sort((a, b) => (a.layer - b.layer) || (a.y - b.y));
    objs.forEach(o => this.drawObject(o));
    this.textQueue.forEach(cmd => {
      this.ctx.fillStyle = '#d4d4d4';
      this.ctx.font = '11px monospace';
      this.ctx.fillText(cmd.text, cmd.x - LullangCamera.x, cmd.y - LullangCamera.y);
    });
  }
  drawObject(o) {
    const ctx = this.ctx;
    const sx = o.x - LullangCamera.x, sy = o.y - LullangCamera.y;
    ctx.save();
    ctx.translate(sx + o.width / 2, sy + o.height / 2);
    ctx.rotate((o.angle || 0) * Math.PI / 180);
    ctx.scale(o.scale || 1, o.scale || 1);
    if (o.sprite && LullangSpriteManager.get(o.sprite)) {
      LullangSpriteManager.draw(ctx, o.sprite, -o.width / 2, -o.height / 2, Math.max(2, Math.floor(o.width / 6)));
    } else {
      ctx.fillStyle = o.color;
      ctx.fillRect(-o.width / 2, -o.height / 2, o.width, o.height);
    }
    ctx.restore();
  }
}

/* =========================================================================
   11. STATEMENT PARSER (line-based, brace-aware) -> program AST
   ========================================================================= */
class LullangStatementParser {
  constructor(sourceText) { this.lines = sourceText.replace(/\r\n/g, '\n').split('\n'); this.idx = 0; }
  peekLine() { return this.idx < this.lines.length ? this.lines[this.idx] : null; }
  nextLine() { return this.lines[this.idx++]; }

  parseProgram() {
    const stmts = [];
    while (this.idx < this.lines.length) {
      const raw = this.peekLine();
      if (raw === null) break;
      const trimmed = raw.trim();
      if (trimmed === '' || trimmed.startsWith('//')) { this.idx++; continue; }
      if (trimmed.startsWith('}')) break;
      stmts.push(this.parseStatement());
    }
    return stmts;
  }

  parseBlock() {
    const body = this.parseProgram();
    if (this.idx >= this.lines.length) throw new LullangError('SYNTAX', '블록이 "}" 로 닫히지 않았습니다.', this.idx + 1, '중괄호 짝을 맞춰주세요.');
    const trimmed = this.lines[this.idx].trim();
    if (!trimmed.startsWith('}')) throw new LullangError('SYNTAX', '블록이 "}" 로 닫히지 않았습니다.', this.idx + 1, '중괄호 짝을 맞춰주세요.');
    const remainder = trimmed.slice(1).trim();
    if (remainder.length > 0) this.lines[this.idx] = remainder;
    else this.idx++;
    return body;
  }

  parseIfHeader(line, lineNo) {
    const m = line.match(/^룰랄\s+(.+)\s*\{$/);
    if (!m) throw new LullangError('SYNTAX', '룰랄 <조건> { 형식이 필요합니다.', lineNo, '예: 룰랄 RAM[0] == 0 {');
    const condExpr = parseLullangExpression(m[1]);
    const thenBody = this.parseBlock();
    let elseBody = null;
    const after = this.peekLine();
    if (after !== null && after.trim().startsWith('아니면')) {
      const elseLineNo = this.idx + 1;
      const elseLine = this.nextLine().trim();
      if (elseLine === '아니면 {') elseBody = this.parseBlock();
      else if (elseLine.startsWith('아니면 룰랄')) elseBody = [this.parseIfHeader(elseLine.replace(/^아니면\s+/, ''), elseLineNo)];
      else throw new LullangError('SYNTAX', '"아니면" 또는 "아니면 룰랄" 형식이 필요합니다.', elseLineNo, '예: } 아니면 { 또는 } 아니면 룰랄 조건 {');
    }
    return { type: 'if', condExpr, thenBody, elseBody, line: lineNo };
  }

  parseStatement() {
    const lineNo = this.idx + 1;
    const raw = this.nextLine();
    const line = raw.trim();

    if (line === 'MAP') {
      const rows = [];
      while (this.peekLine() !== null && this.peekLine().trim() !== 'ENDMAP') rows.push(this.nextLine());
      if (this.peekLine() === null) throw new LullangError('SYNTAX', 'MAP 블록이 ENDMAP으로 닫히지 않았습니다.', lineNo, 'ENDMAP을 추가하세요.');
      this.nextLine();
      return { type: 'map', rows, line: lineNo };
    }
    if (line === 'CLEAR') return { type: 'clear', line: lineNo };
    if (line === 'RENDER') return { type: 'render', line: lineNo };
    if (line.startsWith('TEXT ')) {
      const m = line.match(/^TEXT\s+(\S+)\s+(\S+)\s+"(.*)"$/);
      if (!m) throw new LullangError('SYNTAX', 'TEXT 문법 오류', lineNo, 'TEXT x y "문자열" 형태여야 합니다.');
      return { type: 'text', xExpr: parseLullangExpression(m[1]), yExpr: parseLullangExpression(m[2]), text: m[3], line: lineNo };
    }
    if (line.startsWith('WALL ')) {
      const parts = line.split(/\s+/).slice(1);
      if (parts.length < 4) throw new LullangError('SYNTAX', 'WALL x y w h 형식이 필요합니다.', lineNo, 'WALL 10 10 20 20');
      return { type: 'wall', xExpr: parseLullangExpression(parts[0]), yExpr: parseLullangExpression(parts[1]), wExpr: parseLullangExpression(parts[2]), hExpr: parseLullangExpression(parts[3]), line: lineNo };
    }
    if (line.startsWith('OBJECT ')) {
      const parts = line.split(/\s+/).slice(1);
      if (parts.length < 6) throw new LullangError('SYNTAX', 'OBJECT id TYPE x y w h [color] 형식이 필요합니다.', lineNo, '예: OBJECT 1 PLAYER 10 10 20 20 #4da3ff');
      return { type: 'object', id: parts[0], objType: parts[1], xExpr: parseLullangExpression(parts[2]), yExpr: parseLullangExpression(parts[3]), wExpr: parseLullangExpression(parts[4]), hExpr: parseLullangExpression(parts[5]), color: parts[6] || null, line: lineNo };
    }
    if (line.startsWith('SET ')) {
      const rest = line.slice(4).trim();
      const ramMatch = rest.match(/^RAM\[(.+?)\]\s*=?\s*(.+)$/);
      if (ramMatch) return { type: 'set_ram', indexExpr: parseLullangExpression(ramMatch[1]), valueExpr: parseLullangExpression(ramMatch[2]), line: lineNo };
      const parts = rest.split(/\s+/);
      const id = parts[0], prop = parts[1], rawValue = parts.slice(2).join(' ');
      const numericProps = ['X', 'Y', 'WIDTH', 'HEIGHT', 'SIZE', 'ANGLE', 'SCALE', 'VISIBLE', 'ACTIVE', 'LAYER'];
      if (numericProps.includes((prop || '').toUpperCase())) return { type: 'set_prop', id, prop, valueExpr: parseLullangExpression(rawValue), rawValue: null, line: lineNo };
      return { type: 'set_prop', id, prop, valueExpr: null, rawValue, line: lineNo };
    }
    if (line.startsWith('CAMERA ')) {
      const parts = line.split(/\s+/).slice(1);
      if (parts[0] === 'FOLLOW') return { type: 'camera_follow', id: parts[1], line: lineNo };
      if (parts[0] === 'X') return { type: 'camera_axis', axis: 'X', valueExpr: parseLullangExpression(parts[1]), line: lineNo };
      if (parts[0] === 'Y') return { type: 'camera_axis', axis: 'Y', valueExpr: parseLullangExpression(parts[1]), line: lineNo };
      if (parts[0] === 'ZOOM') return { type: 'camera_zoom', valueExpr: parseLullangExpression(parts[1]), line: lineNo };
      throw new LullangError('SYNTAX', '알 수 없는 CAMERA 명령: ' + parts[0], lineNo, 'FOLLOW/X/Y/ZOOM 중 하나를 사용하세요.');
    }
    if (line.startsWith('TOUCH ')) {
      const m = line.match(/^TOUCH\s+(\S+)\s+(\S+)\s*\{$/);
      if (!m) throw new LullangError('SYNTAX', 'TOUCH typeA typeB { 형식이 필요합니다.', lineNo, '예: TOUCH PLAYER ENEMY {');
      const body = this.parseBlock();
      return { type: 'touch', typeA: m[1], typeB: m[2], body, line: lineNo };
    }
    if (line.startsWith('룰랄 ')) return this.parseIfHeader(line, lineNo);
    if (line.startsWith('루루 FUNCTION ')) {
      const name = line.slice('루루 FUNCTION '.length).trim();
      const body = this.parseProgram();
      const endLine = this.nextLine();
      if (!endLine || endLine.trim() !== '루루 END') throw new LullangError('SYNTAX', '함수가 "루루 END" 로 닫히지 않았습니다.', lineNo, '함수 끝에 루루 END를 추가하세요.');
      return { type: 'func_def', name, body, line: lineNo };
    }
    if (line.startsWith('루루 CALL ')) return { type: 'func_call', name: line.slice('루루 CALL '.length).trim(), line: lineNo };
    if (line.startsWith('루루 SPRITE ')) {
      const name = line.slice('루루 SPRITE '.length).replace(/\{$/, '').trim();
      const rows = [];
      while (this.peekLine() !== null && this.peekLine().trim() !== '}') rows.push(this.nextLine());
      if (this.peekLine() === null) throw new LullangError('SYNTAX', 'SPRITE 블록이 "}" 로 닫히지 않았습니다.', lineNo, '스프라이트 끝에 }를 추가하세요.');
      this.nextLine();
      return { type: 'sprite_def', name, rows, line: lineNo };
    }
    throw new LullangError('SYNTAX', '알 수 없는 명령: "' + line + '"', lineNo, '지원되는 명령어(SET/OBJECT/WALL/CLEAR/RENDER/TEXT/룰랄/루루/TOUCH/CAMERA/MAP)를 확인하세요.');
  }
}

/* =========================================================================
   12. INTERPRETER / VM
   ========================================================================= */
function evaluateLullangExpr(node) {
  switch (node.type) {
    case 'num': return node.value;
    case 'str': return node.value;
    case 'ident': return 0;
    case 'ram': return RAM[Math.max(0, Math.min(RAM_SIZE - 1, Math.floor(evaluateLullangExpr(node.index))))];
    case 'iscollide': return LullangCollision.isCollidingById(evaluateLullangExpr(node.a), evaluateLullangExpr(node.b)) ? 1 : 0;
    case 'unop': { const v = evaluateLullangExpr(node.expr); if (node.op === '!') return v ? 0 : 1; if (node.op === '-') return -v; break; }
    case 'logic': { const l = evaluateLullangExpr(node.left); if (node.op === '&&') return (l && evaluateLullangExpr(node.right)) ? 1 : 0; if (node.op === '||') return (l || evaluateLullangExpr(node.right)) ? 1 : 0; break; }
    case 'binop': {
      const l = evaluateLullangExpr(node.left), r = evaluateLullangExpr(node.right);
      switch (node.op) {
        case '+': return l + r; case '-': return l - r; case '*': return l * r;
        case '/': return r === 0 ? 0 : l / r; case '%': return r === 0 ? 0 : l % r;
        case '>': return l > r ? 1 : 0; case '<': return l < r ? 1 : 0;
        case '>=': return l >= r ? 1 : 0; case '<=': return l <= r ? 1 : 0;
        case '==': return l === r ? 1 : 0; case '!=': return l !== r ? 1 : 0;
      }
      break;
    }
  }
  return 0;
}

class LullangInterpreterClass {
  constructor() { this.functions = new Map(); this.mainBody = []; }
  compile(sourceText) {
    this.functions.clear(); this.mainBody = [];
    const program = new LullangStatementParser(sourceText).parseProgram();
    program.forEach(stmt => {
      if (stmt.type === 'func_def') { this.functions.set(stmt.name, stmt.body); }
      else if (stmt.type === 'sprite_def') { LullangSpriteManager.register(stmt.name, stmt.rows); this.mainBody.push(stmt); }
      else if (stmt.type === 'map') { LullangTileManager.loadMap(stmt.rows); this.mainBody.push(stmt); }
      else this.mainBody.push(stmt);
    });
    this.checkWarnings(program);
    return program;
  }
  checkWarnings(program) {
    const calledNames = new Set();
    const collectCalls = (list) => list.forEach(s => {
      if (s.type === 'func_call') calledNames.add(s.name);
      if (s.thenBody) collectCalls(s.thenBody);
      if (s.elseBody) collectCalls(s.elseBody);
      if (s.body) collectCalls(s.body);
    });
    collectCalls(program);
    this.functions.forEach((body, name) => {
      if (!calledNames.has(name)) pushProblem('warning', 'UNUSED', '함수 "' + name + '" 가 정의되었지만 호출되지 않습니다.', '?', '루루 CALL ' + name + ' 을 추가하거나 불필요하면 제거하세요.');
    });
  }
  execStatements(list) { list.forEach(stmt => this.execStatement(stmt)); }
  execStatement(stmt) {
    switch (stmt.type) {
      case 'clear': LullangRenderer.clear(); return;
      case 'render': LullangRenderer.flush(); return;
      case 'text': LullangRenderer.pushText(evaluateLullangExpr(stmt.xExpr), evaluateLullangExpr(stmt.yExpr), stmt.text); return;
      case 'wall': {
        const x = evaluateLullangExpr(stmt.xExpr), y = evaluateLullangExpr(stmt.yExpr), w = evaluateLullangExpr(stmt.wExpr), h = evaluateLullangExpr(stmt.hExpr);
        LullangObjectManager.createOrUpdate('wall_' + Math.round(x) + '_' + Math.round(y), 'WALL', x, y, w, h, '#3c3c3c');
        return;
      }
      case 'object': {
        const x = evaluateLullangExpr(stmt.xExpr), y = evaluateLullangExpr(stmt.yExpr), w = evaluateLullangExpr(stmt.wExpr), h = evaluateLullangExpr(stmt.hExpr);
        const existed = LullangObjectManager.get(stmt.id);
        LullangObjectManager.createOrUpdate(stmt.id, stmt.objType, x, y, w, h, stmt.color);
        if (!existed) consoleLog('info', 'OBJECT 생성: ' + stmt.id + ' (' + stmt.objType + ')');
        return;
      }
      case 'set_ram': {
        const idx = Math.max(0, Math.min(RAM_SIZE - 1, Math.floor(evaluateLullangExpr(stmt.indexExpr))));
        RAM[idx] = evaluateLullangExpr(stmt.valueExpr);
        return;
      }
      case 'set_prop': {
        const value = stmt.valueExpr !== null ? evaluateLullangExpr(stmt.valueExpr) : stmt.rawValue;
        LullangObjectManager.setProperty(stmt.id, stmt.prop, value);
        return;
      }
      case 'if': {
        const cond = evaluateLullangExpr(stmt.condExpr);
        if (cond) this.execStatements(stmt.thenBody);
        else if (stmt.elseBody) this.execStatements(stmt.elseBody);
        return;
      }
      case 'touch': {
        if (LullangCollision.anyCollidingByType(stmt.typeA, stmt.typeB)) this.execStatements(stmt.body);
        return;
      }
      case 'func_call': {
        const body = this.functions.get(stmt.name);
        if (!body) { pushProblem('error', 'RUNTIME', '정의되지 않은 함수 호출: ' + stmt.name, stmt.line, '루루 FUNCTION ' + stmt.name + ' 을 먼저 정의하세요.'); return; }
        this.execStatements(body);
        return;
      }
      case 'camera_follow': LullangCamera.follow(stmt.id); return;
      case 'camera_axis': if (stmt.axis === 'X') LullangCamera.x = evaluateLullangExpr(stmt.valueExpr); else LullangCamera.y = evaluateLullangExpr(stmt.valueExpr); return;
      case 'camera_zoom': LullangCamera.zoom = Math.max(0.1, evaluateLullangExpr(stmt.valueExpr)); return;
      case 'func_def': case 'sprite_def': case 'map': return;
      default: return;
    }
  }
  runFrame() { this.execStatements(this.mainBody); }
}
const LullangInterpreter = new LullangInterpreterClass();

