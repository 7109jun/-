    return program;
  }
  // OOP: 클래스 본문(필드 기본값 + 메서드)을 필드맵/메서드맵으로 등록. 확장(상속) 부모 이름은 문자열로만 저장하고
  // 실제 필드/메서드 상속 해석은 인스턴스화(NEW)/메서드 호출 시점에 부모 체인을 따라 올라가며 처리한다.
  registerClass(stmt) {
    const fields = new Map(), methods = new Map();
