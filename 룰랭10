let autocompleteMatches = [], autocompleteIndex = 0;
function getLinePrefixTrimmed() {
  const start = editorInput.selectionStart;
  const value = editorInput.value;
  const lineStart = value.lastIndexOf('\n', start - 1) + 1;
  return value.slice(lineStart, start).replace(/^[ \t]+/, '');
}
function updateAutocomplete() {
  const prefix = getLinePrefixTrimmed();
  if (prefix.length < 1) { hideAutocomplete(); return; }
  autocompleteMatches = LULLANG_KEYWORDS.filter(k => k.startsWith(prefix) && k.trim() !== prefix.trim()).slice(0, 8);
  if (!autocompleteMatches.length) { hideAutocomplete(); return; }
  autocompleteIndex = 0;
