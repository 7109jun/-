      case 'camera_axis': if (stmt.axis === 'X') LullangCamera.x = evaluateLullangExpr(stmt.valueExpr); else LullangCamera.y = evaluateLullangExpr(stmt.valueExpr); return;
      case 'camera_zoom': LullangCamera.zoom = Math.max(0.1, evaluateLullangExpr(stmt.valueExpr)); return;
      case 'camera_mode': LullangCamera.mode = (stmt.mode === '3D') ? '3D' : '2D'; return;
      case 'camera_angle': LullangCamera.angle = evaluateLullangExpr(stmt.valueExpr); return;
      case 'repeat': {
