        clone.sprite = src.sprite; clone.animation = src.animation; clone.animStartTime = src.animStartTime;
        clone._class = src._class;
        clone.classFields = src.classFields ? Object.assign({}, src.classFields) : null;
        consoleLog('info', '복제됨: ' + newId + ' (원본: ' + stmt.sourceId + ')');
