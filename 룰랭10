      if (act === 'copy' || act === 'cut') {
        const text = editorInput.value.slice(s, en);
        try { await navigator.clipboard.writeText(text); } catch (err) { /* 클립보드 권한 없으면 조용히 무시 */ }
        if (act === 'cut') {
          editorInput.value = editorInput.value.slice(0, s) + editorInput.value.slice(en);
          editorInput.selectionStart = editorInput.selectionEnd = s;
          refreshEditorView(); LullangFS.save(editorInput.value);
