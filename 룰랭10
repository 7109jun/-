}

// 변수/리스트 "선언 전 사용" 정적 검사. 함수 본문은 호출 시점을 컴파일 타임에 알 수 없으므로
// "프로그램 어디선가 선언된 적이 있는가"로 검사하고, 최상위(top-level) 코드는 위→아래 실행 순서 그대로 검사한다.
function checkLullangDeclarationOrder(program) {
  const allDeclared = new Set();
  const collectAll = (list) => list.forEach(s => {
    if (s.type === 'var_decl' || s.type === 'list_decl') allDeclared.add(s.name);
    if (s.thenBody) collectAll(s.thenBody);
    if (s.elseBody) collectAll(s.elseBody);
    if (s.body) collectAll(s.body);
  });
  collectAll(program);

  function checkExprNames(node, knownSet, lineNo) {
    if (!node || typeof node !== 'object') return;
    if (node.type === 'ident' || node.type === 'listget') {
      if (node.type === 'ident' && (node.name in LULLANG_BUILTIN_CONSTS)) { /* 내장 상수는 선언 불필요 */ }
      else if (!knownSet.has(node.name)) {
        throw new LullangError('DECLARATION', '선언되지 않은 변수 "' + node.name + '" 를 사용했습니다.', lineNo, '먼저 "변수 ' + node.name + '는 값" 또는 "리스트 ' + node.name + '는 [값, 값, ...]" 으로 선언한 뒤 사용하세요.');
      }
    }
    ['left', 'right', 'expr', 'index', 'a', 'b'].forEach(k => { if (node[k]) checkExprNames(node[k], knownSet, lineNo); });
    if (node.args) node.args.forEach(a => checkExprNames(a, knownSet, lineNo));
  }
  function checkStmtExprs(stmt, knownSet) {
    ['xExpr', 'yExpr', 'wExpr', 'hExpr', 'valueExpr', 'indexExpr', 'condExpr'].forEach(f => { if (stmt[f]) checkExprNames(stmt[f], knownSet, stmt.line); });
    if (stmt.itemExprs) stmt.itemExprs.forEach(e => checkExprNames(e, knownSet, stmt.line));
    if (stmt.argExprs) stmt.argExprs.forEach(e => checkExprNames(e, knownSet, stmt.line));
  }
  function walkFuncBody(list, paramNames) {
    const known = paramNames && paramNames.length ? new Set([...allDeclared, ...paramNames]) : allDeclared;
    list.forEach(s => {
      checkStmtExprs(s, known);
      if (s.thenBody) walkFuncBody(s.thenBody, paramNames);
      if (s.elseBody) walkFuncBody(s.elseBody, paramNames);
      if (s.body) walkFuncBody(s.body, paramNames);
    });
  }
  const declaredSoFar = new Set();
  function walkTopLevel(list) {
    list.forEach(s => {
      if (s.type === 'func_def') { walkFuncBody(s.body, s.params); return; }
      checkStmtExprs(s, declaredSoFar);
      if (s.thenBody) walkTopLevel(s.thenBody);
      if (s.elseBody) walkTopLevel(s.elseBody);
      if (s.body) walkTopLevel(s.body);
      if (s.type === 'var_decl' || s.type === 'list_decl') declaredSoFar.add(s.name);
    });
  }
  walkTopLevel(program);
}

class LullangInterpreterClass {
  constructor() { this.functions = new Map(); this.mainBody = []; this.classes = new Map(); this.callDepth = 0; }
  compile(sourceText) {
    this.functions.clear(); this.mainBody = []; this.classes.clear();
    const program = new LullangStatementParser(sourceText).parseProgram();
    checkLullangDeclarationOrder(program);
    program.forEach(stmt => {
      if (stmt.type === 'func_def') { this.functions.set(stmt.name, { params: stmt.params || [], body: stmt.body }); }
      else if (stmt.type === 'sprite_def') { LullangSpriteManager.register(stmt.name, stmt.rows); this.mainBody.push(stmt); }
      else if (stmt.type === 'shape_def') { LullangShapeManager.register(stmt.name, parseLullangShapeRows(stmt.rawRows)); this.mainBody.push(stmt); }
      else if (stmt.type === 'animation_def') { LullangAnimationManager.register(stmt.name, stmt.frames); this.mainBody.push(stmt); }
      else if (stmt.type === 'pixelart_def') { LullangPixelArtManager.register(stmt.name, stmt.width, stmt.height, parseLullangPixelArtRows(stmt.rawRows)); this.mainBody.push(stmt); }
      else if (stmt.type === 'image_load') { LullangImageManager.load(stmt.name, stmt.url); this.mainBody.push(stmt); }
      else if (stmt.type === 'sound_load') { LullangAudio.load(stmt.name, stmt.url); this.mainBody.push(stmt); }
      else if (stmt.type === 'map') { LullangTileManager.loadMap(stmt.rows); this.mainBody.push(stmt); }
      else if (stmt.type === 'class_def') { this.registerClass(stmt); }
      else this.mainBody.push(stmt);
