   ========================================================================= */
const loadedFromEmbeddedSave = loadEmbeddedSaveIfPresent();
renderExplorer();
loadFileIntoEditor(LullangFS.activeFile);
renderConsole();
renderProblems();
consoleLog('info', loadedFromEmbeddedSave
  ? 'Lullang IDE v4.0 — 이전에 저장된 상태를 불러왔습니다. (Tab: 매뉴얼 열기/닫기)'
  : 'Lullang IDE v4.0 초기화 완료. RUN을 눌러 main.lul을 실행하세요. (Tab: 매뉴얼 열기/닫기)');
})();
