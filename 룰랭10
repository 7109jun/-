    this.classes.set(stmt.name, { parent: stmt.parent, fields, methods });
  }
  resolveClassFieldDefaults(className) {
    const chain = []; let cur = className;
    while (cur) { const c = this.classes.get(cur); if (!c) break; chain.unshift(c); cur = c.parent; }
    const merged = new Map();
    chain.forEach(c => c.fields.forEach((expr, name) => merged.set(name, expr)));
    return merged;
  }
  resolveClassMethod(className, methodName) {
    let cur = className;
    while (cur) {
      const c = this.classes.get(cur);
      if (!c) return null;
      if (c.methods.has(methodName)) return c.methods.get(methodName);
      cur = c.parent;
    }
    return null;
  }
  checkWarnings(program) {
    const calledNames = new Set();
    const collectCalls = (list) => list.forEach(s => {
      if (s.type === 'func_call') calledNames.add(s.name);
      if (s.thenBody) collectCalls(s.thenBody);
      if (s.elseBody) collectCalls(s.elseBody);
      if (s.body) collectCalls(s.body);
    });
    collectCalls(program);
    this.functions.forEach((body, name) => {
      if (!calledNames.has(name)) pushProblem('warning', 'UNUSED', '함수 "' + name + '" 가 정의되었지만 호출되지 않습니다.', '?', '루루 CALL ' + name + ' 을 추가하거나 불필요하면 제거하세요.');
    });
  }
  execStatements(list) {
