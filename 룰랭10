function assignAutoAgeAndLayer(name) {
  let maxAge = 0, maxLayer = 0;
  LullangFS.order.forEach(f => {
    if (f === name) return;
    maxAge = Math.max(maxAge, LullangFS.getAge(f));
    maxLayer = Math.max(maxLayer, LullangFS.getLayer(f));
