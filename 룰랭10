  if (LullangFS.order.length <= 1) { alert('마지막 남은 파일은 삭제할 수 없습니다.'); return; }
  const idx = LullangFS.order.indexOf(name);
  if (idx === -1) return;
  LullangFS.order.splice(idx, 1);
  delete LullangFS.files[name];
  delete LullangFS.meta[name];
  fileDeleteClickState.delete(name);
  if (LullangFS.activeFile === name) {
    const next = LullangFS.order[Math.max(0, idx - 1)] || LullangFS.order[0];
    loadFileIntoEditor(next);
  } else {
    renderExplorer();
  }
  consoleLog('info', '파일 삭제됨: ' + name);
}
function deleteLullangFile(name) {
  if (LULLANG_RESERVED_FILES.includes(name)) { alert('"' + name + '" 은(는) 시스템 파일이라 삭제할 수 없습니다.'); return; }
  if (LullangFS.order.length <= 1) { alert('마지막 남은 파일은 삭제할 수 없습니다.'); return; }
  if (!confirm('"' + name + '" 파일을 삭제할까요? 되돌릴 수 없습니다.')) return;
  deleteLullangFileImmediate(name);
}
// 휴지통 아이콘 전용: 브라우저 confirm 대화상자 대신, 한 번 더 눌러서 확인하는 2단계 클릭 방식
// (마우스를 대화상자까지 옮기는 불편함을 없애기 위함 - 5연타는 너무 번거로워서 2클릭으로 단순화)
const TRASH_CONFIRM_WINDOW_MS = 3000;
const fileDeleteClickState = new Map(); // name -> { timer }
function handleTrashIconClick(name, iconEl) {
  if (LULLANG_RESERVED_FILES.includes(name)) { alert('"' + name + '" 은(는) 시스템 파일이라 삭제할 수 없습니다.'); return; }
  const state = fileDeleteClickState.get(name);
  if (state) {
    clearTimeout(state.timer);
    fileDeleteClickState.delete(name);
    iconEl.textContent = 'X';
    iconEl.title = '삭제';
    deleteLullangFileImmediate(name);
    return;
  }
  fileDeleteClickState.set(name, {
    timer: setTimeout(() => {
      fileDeleteClickState.delete(name);
      iconEl.textContent = 'X';
      iconEl.title = '삭제';
    }, TRASH_CONFIRM_WINDOW_MS)
  });
  iconEl.textContent = '확인?';
  iconEl.title = '한 번 더 누르면 삭제됩니다 (3초 안에)';
}

function renameLullangFile(name) {
  const newName = prompt('새 이름', name);
  if (!newName || newName === name) return;
  const finalName = newName.endsWith('.lul') ? newName : newName + '.lul';
  if (LullangFS.files[finalName] !== undefined) { alert('이미 존재하는 파일입니다.'); return; }
  LullangFS.files[finalName] = LullangFS.files[name];
  delete LullangFS.files[name];
  const idx = LullangFS.order.indexOf(name);
  LullangFS.order[idx] = finalName;
  if (LullangFS.activeFile === name) LullangFS.activeFile = finalName;
  loadFileIntoEditor(LullangFS.activeFile);
}

function duplicateLullangFile(name) {
  let base = name.replace(/\.lul$/, '') + '_copy';
  let finalName = base + '.lul';
  let n = 2;
  while (LullangFS.files[finalName] !== undefined) { finalName = base + n + '.lul'; n++; }
  LullangFS.files[finalName] = LullangFS.files[name];
  LullangFS.order.push(finalName);
  loadFileIntoEditor(finalName);
}

