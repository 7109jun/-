        case '+': return l + r; case '-': return l - r; case '*': return l * r;
        case '/': return r === 0 ? 0 : l / r; case '%': return r === 0 ? 0 : l % r;
        case '>': return l > r ? 1 : 0; case '<': return l < r ? 1 : 0;
        case '>=': return l >= r ? 1 : 0; case '<=': return l <= r ? 1 : 0;
        case '==': return l === r ? 1 : 0; case '!=': return l !== r ? 1 : 0;
