          const text = await navigator.clipboard.readText();
          editorInput.value = editorInput.value.slice(0, s) + text + editorInput.value.slice(en);
          editorInput.selectionStart = editorInput.selectionEnd = s + text.length;
          refreshEditorView(); LullangFS.save(editorInput.value);
        } catch (err) { alert('클립보드 읽기 권한이 없습니다. Ctrl+V를 사용해주세요.'); }
      } else if (act === 'selectall') {
