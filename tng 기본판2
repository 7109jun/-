tng 기본판이 더 좋아졌습니다!
원래 기본판보다 이걸 쓰는게 더 편할거에요 🤯
<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>TNG (Text Network Graphics) Hybrid Engine v5.0</title>
    <style>
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: #f4f7f6;
            color: #333;
            margin: 0;
            padding: 40px 20px;
            display: flex;
            flex-direction: column;
            align-items: center;
        }
        h1 { color: #2c3e50; margin-bottom: 5px; }
        .philosophy { font-style: italic; color: #7f8c8d; margin-bottom: 30px; text-align: center; }
        .container {
            background: white;
            padding: 30px;
            border-radius: 12px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.05);
            max-width: 650px;
            width: 100%;
            margin-bottom: 20px;
        }
        .section { margin-bottom: 25px; padding-bottom: 20px; border-bottom: 1px solid #eee; }
        .section:last-child { border-bottom: none; margin-bottom: 0; padding-bottom: 0; }
        h3 { margin-top: 0; color: #34495e; }
        input[type="file"] { display: block; margin: 10px 0; }
        textarea {
            width: 100%;
            height: 140px;
            margin: 10px 0;
            padding: 10px;
            border: 1px solid #ddd;
            border-radius: 6px;
            font-family: monospace;
            font-size: 11px;
            resize: vertical;
            box-sizing: border-box;
            background-color: #fafafa;
            word-break: break-all;
        }
        button {
            background-color: #9b59b6;
            color: white;
            border: none;
            padding: 10px 15px;
            font-size: 14px;
            border-radius: 6px;
            cursor: pointer;
            transition: background 0.2s;
            margin-right: 5px;
            margin-bottom: 5px;
        }
        button:hover { background-color: #8e44ad; }
        button:disabled { background-color: #bdc3c7; cursor: not-allowed; }
        .copy-btn { background-color: #e74c3c; }
        .copy-btn:hover { background-color: #c0392b; }
        .image-download-btn { background-color: #e67e22; }
        .image-download-btn:hover { background-color: #d35400; }
        #preview, #restoreCanvas {
            max-width: 100%;
            max-height: 250px;
            margin-top: 15px;
            border-radius: 6px;
            display: none;
            box-shadow: 0 2px 8px rgba(0,0,0,0.1);
        }
        .status { font-size: 12px; color: #9b59b6; font-weight: bold; margin-top: 5px; }
    </style>
</head>
<body>

    <h1>TNG 이미지 엔진 v5.0 (하이브리드 무손실)</h1>
    <div class="philosophy">"처음 아이디어 그대로, 화질은 완벽하게 합치다"<br>형식: [W:가로|H:세로](R,G,B),(R,G,B)... (100% 원본 해상도)</div>

    <div class="container">
        <div class="section">
            <h3>1. 사진 ➡️ 무손실 픽셀 텍스트 변환</h3>
            <p style="font-size: 13px; color: #666;">이미지의 모든 픽셀을 100% 원본 화질 그대로 TNG 텍스트로 추출합니다.</p>
            <input type="file" id="imageInput" accept="image/jpeg, image/png">
            <div id="convertStatus" class="status"></div>
            <img id="preview" alt="원본 미리보기">
            <textarea id="tngOutput" readonly placeholder="변환된 TNG RGB 데이터가 여기에 표시됩니다..."></textarea>
            <button id="copyBtn" class="copy-btn" disabled>TNG RGB 텍스트 복사하기</button>
        </div>

        <div class="section">
            <h3>2. 무손실 픽셀 텍스트 ➡️ 사진 복원</h3>
            <p style="font-size: 13px; color: #666;">공유받은 무손실 TNG 코드를 붙여넣으세요.</p>
            <textarea id="tngInput" placeholder="[W:X|H:Y](R,G,B),(R,G,B)... 형태의 코드를 붙여넣으세요..."></textarea>
            <div id="restoreStatus" class="status"></div>
            <div class="btn-group">
                <button id="restoreBtn">이미지 복원하기</button>
                <button id="imageDownloadBtn" class="image-download-btn" disabled>이 사진 컴퓨터에 저장</button>
            </div>
            <br>
            <canvas id="restoreCanvas"></canvas>
        </div>
    </div>

    <script>
        const imageInput = document.getElementById('imageInput');
        const preview = document.getElementById('preview');
        const tngOutput = document.getElementById('tngOutput');
        const copyBtn = document.getElementById('copyBtn');
        const convertStatus = document.getElementById('convertStatus');
        
        const tngInput = document.getElementById('tngInput');
        const restoreBtn = document.getElementById('restoreBtn');
        const imageDownloadBtn = document.getElementById('imageDownloadBtn');
        const restoreCanvas = document.getElementById('restoreCanvas');
        const restoreStatus = document.getElementById('restoreStatus');

        // [기능 1] 리사이징 없이 원본 해상도 그대로 픽셀을 텍스트화
        imageInput.addEventListener('change', function(e) {
            const file = e.target.files[0];
            if (!file) return;

            const reader = new FileReader();
            reader.onload = function(event) {
                preview.src = event.target.result;
                preview.style.display = 'block';

                const img = new Image();
                img.onload = function() {
                    const canvas = document.createElement('canvas');
                    const ctx = canvas.getContext('2d');
                    
                    // ★★★ 화질 저하의 주범인 scale 코드를 빼고 원본 크기 그대로 설정! ★★★
                    canvas.width = img.width;
                    canvas.height = img.height;
                    
                    ctx.drawImage(img, 0, 0);
                    
                    const imgData = ctx.getImageData(0, 0, canvas.width, canvas.height);
                    const data = imgData.data; 
                    
                    convertStatus.innerText = `픽셀 분석 중... (총 ${canvas.width * canvas.height}개 픽셀)`;

                    // 고화질 대용량 데이터를 빠르게 처리하기 위해 일반 배열 대신 문자열 결합 최적화
                    let rgbText = `[W:${canvas.width}|H:${canvas.height}]`;
                    const parts = [];
                    
                    for (let i = 0; i < data.length; i += 4) {
                        parts.push(`(${data[i]},${data[i+1]},${data[i+2]})`);
                        // 메모리 과부하 방지를 위해 주기적으로 문자열 합치기
                        if (parts.length > 10000) {
                            rgbText += parts.join(',') + ',';
                            parts.length = 0;
                        }
                    }
                    if (parts.length > 0) {
                        rgbText += parts.join(',');
                    } else if (rgbText.endsWith(',')) {
                        rgbText = rgbText.slice(0, -1);
                    }

                    tngOutput.value = rgbText;
                    convertStatus.innerText = `변환 완료! (텍스트 크기: ${(rgbText.length / 1024).toFixed(1)} KB)`;
                    copyBtn.disabled = false;
                };
                img.src = event.target.result;
            };
            reader.readAsDataURL(file);
        });

        // [기능 2] 픽셀 텍스트를 고속으로 파싱하여 원본 화질로 복원
        restoreBtn.addEventListener('click', function() {
            const tngText = tngInput.value.trim();
            if (!tngText) {
                alert('TNG RGB 텍스트를 입력해주세요.');
                return;
            }

            try {
                restoreStatus.innerText = "텍스트 파싱 및 100% 화질 복원 중...";

                const headerMatch = tngText.match(/^\[W:(\d+)\|H:(\d+)\]/);
                if (!headerMatch) {
                    alert('크기 정보가 누락되었습니다.');
                    restoreStatus.innerText = "";
                    return;
                }

                const width = parseInt(headerMatch[1]);
                const height = parseInt(headerMatch[2]);
                
                const dataPart = tngText.substring(headerMatch[0].length);
                
                restoreCanvas.width = width;
                restoreCanvas.height = height;
                const ctx = restoreCanvas.getContext('2d');
                const imgData = ctx.createImageData(width, height);
                const data = imgData.data;

                // ★★★ 정규식 match 대신 고속 문자열 파싱 기법 적용 (렉 방지) ★★★
                // "(R,G,B)" 패턴들을 쉼표 단위로 쪼개서 순접 처리
                const pixelArray = dataPart.split('),(');
                let dataIdx = 0;

                for (let i = 0; i < pixelArray.length; i++) {
                    // 첫 번째와 마지막 요소의 괄호 잔여물 제거 정리
                    const cleanStr = pixelArray[i].replace(/[\(\)]/g, '');
                    const rgbValues = cleanStr.split(',');
                    
                    if (rgbValues.length >= 3) {
                        data[dataIdx]     = parseInt(rgbValues[0]); // R
                        data[dataIdx + 1] = parseInt(rgbValues[1]); // G
                        data[dataIdx + 2] = parseInt(rgbValues[2]); // B
                        data[dataIdx + 3] = 255;                    // Alpha
                        dataIdx += 4;
                    }
                    if (dataIdx >= data.length) break;
                }

                ctx.putImageData(imgData, 0, 0);
                restoreCanvas.style.display = 'block';
                restoreStatus.innerText = `복원 성공! (원본 해상도: ${width}x${height})`;
                imageDownloadBtn.disabled = false;

            } catch (error) {
                alert('복원 실패! 데이터 가공 중 에러 발생.');
                restoreStatus.innerText = "";
                console.error(error);
            }
        });

        // 다운로드 기능
        imageDownloadBtn.addEventListener('click', function() {
            const url = restoreCanvas.toDataURL('image/png');
            const a = document.createElement('a');
            a.href = url;
            a.download = 'tng_hybrid_restored.png';
            document.body.appendChild(a);
            a.click();
            document.body.removeChild(a);
        });
    </script>
</body>
</html>
