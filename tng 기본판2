tng 기본판이 더 좋아졌습니다!
원래 기본판보다 이걸 쓰는게 더 편할거에요 🤯
<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>TNG (Text Network Graphics) Ultra Engine v4.0</title>
    <style>
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: #f4f7f6;
            color: #333;
            margin: 0;
            padding: 40px 20px;
            display: flex;
            flex-direction: column;
            align-items: center;
        }
        h1 { color: #2c3e50; margin-bottom: 5px; }
        .philosophy { font-style: italic; color: #7f8c8d; margin-bottom: 30px; text-align: center; }
        .container {
            background: white;
            padding: 30px;
            border-radius: 12px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.05);
            max-width: 650px;
            width: 100%;
            margin-bottom: 20px;
        }
        .section { margin-bottom: 25px; padding-bottom: 20px; border-bottom: 1px solid #eee; }
        .section:last-child { border-bottom: none; margin-bottom: 0; padding-bottom: 0; }
        h3 { margin-top: 0; color: #34495e; }
        input[type="file"] { display: block; margin: 10px 0; }
        textarea {
            width: 100%;
            height: 140px;
            margin: 10px 0;
            padding: 10px;
            border: 1px solid #ddd;
            border-radius: 6px;
            font-family: monospace;
            font-size: 11px;
            resize: vertical;
            box-sizing: border-box;
            background-color: #fafafa;
            word-break: break-all;
        }
        button {
            background-color: #2ecc71;
            color: white;
            border: none;
            padding: 10px 15px;
            font-size: 14px;
            border-radius: 6px;
            cursor: pointer;
            transition: background 0.2s;
            margin-right: 5px;
            margin-bottom: 5px;
        }
        button:hover { background-color: #27ae60; }
        button:disabled { background-color: #bdc3c7; cursor: not-allowed; }
        .copy-btn { background-color: #e74c3c; }
        .copy-btn:hover { background-color: #c0392b; }
        .image-download-btn { background-color: #e67e22; }
        .image-download-btn:hover { background-color: #d35400; }
        #preview, #restoreCanvas {
            max-width: 100%;
            max-height: 250px;
            margin-top: 15px;
            border-radius: 6px;
            display: none;
            box-shadow: 0 2px 8px rgba(0,0,0,0.1);
        }
        .status { font-size: 12px; color: #2ecc71; font-weight: bold; margin-top: 5px; }
    </style>
</head>
<body>

    <h1>TNG 이미지 엔진 v4.0 (Ultra 고화질 무손실)</h1>
    <div class="philosophy">"가장 완벽한 화질 보존과 고속 텍스트 변환"<br>형식: Base64 DataURL 프로토콜</div>

    <div class="container">
        <div class="section">
            <h3>1. 사진 ➡️ 초고화질 텍스트 고속 변환</h3>
            <p style="font-size: 13px; color: #666;">이미지를 올리면 화질 저하 전혀 없이 초고속으로 텍스트를 추출합니다.</p>
            <input type="file" id="imageInput" accept="image/jpeg, image/png, image/webp">
            <div id="convertStatus" class="status"></div>
            <img id="preview" alt="원본 미리보기">
            <textarea id="tngOutput" readonly placeholder="변환된 TNG 고화질 데이터가 여기에 표시됩니다..."></textarea>
            <button id="copyBtn" class="copy-btn" disabled>TNG 텍스트 복사하기</button>
        </div>

        <div class="section">
            <h3>2. 텍스트 ➡️ 원본 사진 100% 복원</h3>
            <p style="font-size: 13px; color: #666;">공유받거나 Github에 저장해 둔 고화질 TNG 텍스트를 붙여넣으세요.</p>
            <textarea id="tngInput" placeholder="data:image/... 형태의 코드를 붙여넣으세요..."></textarea>
            <div id="restoreStatus" class="status"></div>
            <div class="btn-group">
                <button id="restoreBtn">이미지 복원하기</button>
                <button id="imageDownloadBtn" class="image-download-btn" disabled>이 사진 컴퓨터에 저장</button>
            </div>
            <br>
            <canvas id="restoreCanvas"></canvas>
        </div>
    </div>

    <script>
        const imageInput = document.getElementById('imageInput');
        const preview = document.getElementById('preview');
        const tngOutput = document.getElementById('tngOutput');
        const copyBtn = document.getElementById('copyBtn');
        const convertStatus = document.getElementById('convertStatus');
        
        const tngInput = document.getElementById('tngInput');
        const restoreBtn = document.getElementById('restoreBtn');
        const imageDownloadBtn = document.getElementById('imageDownloadBtn');
        const restoreCanvas = document.getElementById('restoreCanvas');
        const restoreStatus = document.getElementById('restoreStatus');

        // [기능 1] 이미지 파일을 화질 손실 없이 고속으로 텍스트화
        imageInput.addEventListener('change', function(e) {
            const file = e.target.files[0];
            if (!file) return;

            convertStatus.innerText = "이미지 데이터 분석 중...";

            const reader = new FileReader();
            reader.onload = function(event) {
                // 화질을 깎아먹던 Canvas 변환 과정을 완전히 빼고, 원본 이진 데이터를 그대로 텍스트(Base64)로 획득!
                const base64Text = event.target.result; 
                
                preview.src = base64Text;
                preview.style.display = 'block';
                tngOutput.value = base64Text;
                
                convertStatus.innerText = `변환 완료! (텍스트 크기: ${(base64Text.length / 1024).toFixed(1)} KB)`;
                copyBtn.disabled = false;
            };
            reader.readAsDataURL(file); // 이 한 줄이 원본 화질을 유지하며 초고속으로 문자를 생성합니다.
        });

        // 클립보드 복사
        copyBtn.addEventListener('click', function() {
            tngOutput.select();
            document.execCommand('copy');
            alert('TNG 고화질 텍스트가 복사되었습니다! Github에 붙여넣어 보관하세요.');
        });

        // [기능 2] 텍스트 데이터를 읽어 원본 크기와 화질 그대로 복원
        restoreBtn.addEventListener('click', function() {
            const tngText = tngInput.value.trim();
            if (!tngText) {
                alert('TNG 고화질 텍스트를 입력해주세요.');
                return;
            }

            try {
                restoreStatus.innerText = "고화질 이미지 데이터 복원 중...";

                const img = new Image();
                img.onload = function() {
                    // 원본 사진의 해상도(가로, 세로)를 100% 그대로 반영
                    restoreCanvas.width = img.width;
                    restoreCanvas.height = img.height;
                    
                    const ctx = restoreCanvas.getContext('2d');
                    ctx.drawImage(img, 0, 0); // 화질 깨짐 전혀 없이 원본 그대로 드로잉
                    
                    restoreCanvas.style.display = 'block';
                    restoreStatus.innerText = `복원 성공! (원본 해상도: ${img.width}x${img.height})`;
                    imageDownloadBtn.disabled = false;
                };
                img.src = tngText; // 인코딩된 텍스트 자체를 이미지 소스로 다이렉트 주입

            } catch (error) {
                alert('복원 실패! 올바른 고화질 TNG 데이터가 아닙니다.');
                restoreStatus.innerText = "";
                console.error(error);
            }
        });

        // 복원된 고화질 이미지를 다시 컴퓨터에 PNG 파일로 저장
        imageDownloadBtn.addEventListener('click', function() {
            const url = restoreCanvas.toDataURL('image/png');
            const a = document.createElement('a');
            a.href = url;
            a.download = 'tng_ultra_restored.png';
            document.body.appendChild(a);
            a.click();
            document.body.removeChild(a);
        });
    </script>
</body>
</html>
