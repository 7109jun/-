tng 2입니다 
기존 글들을 압축하는 기능을 넣었습니다
<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>TNG (Text Network Graphics) RGB Engine v3.0 (Compressed)</title>
    <style>
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: #f4f7f6;
            color: #333;
            margin: 0;
            padding: 40px 20px;
            display: flex;
            flex-direction: column;
            align-items: center;
        }
        h1 { color: #2c3e50; margin-bottom: 5px; }
        .philosophy { font-style: italic; color: #7f8c8d; margin-bottom: 30px; text-align: center; }
        .container {
            background: white;
            padding: 30px;
            border-radius: 12px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.05);
            max-width: 650px;
            width: 100%;
            margin-bottom: 20px;
        }
        .section { margin-bottom: 25px; padding-bottom: 20px; border-bottom: 1px solid #eee; }
        .section:last-child { border-bottom: none; margin-bottom: 0; padding-bottom: 0; }
        h3 { margin-top: 0; color: #34495e; }
        input[type="file"] { display: block; margin: 10px 0; }
        textarea {
            width: 100%;
            height: 140px;
            margin: 10px 0;
            padding: 10px;
            border: 1px solid #ddd;
            border-radius: 6px;
            font-family: monospace;
            font-size: 11px;
            resize: vertical;
            box-sizing: border-box;
            background-color: #fafafa;
            word-break: break-all;
        }
        button {
            background-color: #3498db;
            color: white;
            border: none;
            padding: 10px 15px;
            font-size: 14px;
            border-radius: 6px;
            cursor: pointer;
            transition: background 0.2s;
            margin-right: 5px;
            margin-bottom: 5px;
        }
        button:hover { background-color: #2980b9; }
        button:disabled { background-color: #bdc3c7; cursor: not-allowed; }
        .copy-btn { background-color: #e74c3c; }
        .copy-btn:hover { background-color: #c0392b; }
        .image-download-btn { background-color: #e67e22; }
        .image-download-btn:hover { background-color: #d35400; }
        #preview, #restoreCanvas {
            max-width: 100%;
            max-height: 250px;
            margin-top: 15px;
            border-radius: 6px;
            display: none;
            box-shadow: 0 2px 8px rgba(0,0,0,0.1);
        }
        .status { font-size: 12px; color: #e67e22; font-weight: bold; margin-top: 5px; }
    </style>
</head>
<body>

    <h1>TNG 이미지 엔진 v3.0 (초경량 압축형)</h1>
    <div class="philosophy">"가장 직관적인 픽셀의 텍스트 압축"<br>형식: [W:가로|H:세로]개수*(R,G,B),개수*(R,G,B)...</div>

    <div class="container">
        <div class="section">
            <h3>1. 사진 ➡️ RGB 텍스트 압축 변환</h3>
            <p style="font-size: 13px; color: #666;">이미지를 올리면 같은 색상의 픽셀들을 압축하여 텍스트로 추출합니다.</p>
            <input type="file" id="imageInput" accept="image/jpeg, image/png">
            <div id="convertStatus" class="status"></div>
            <img id="preview" alt="원본 미리보기">
            <textarea id="tngOutput" readonly placeholder="변환된 TNG RGB 데이터가 여기에 표시됩니다..."></textarea>
            <button id="copyBtn" class="copy-btn" disabled>TNG RGB 텍스트 복사하기</button>
        </div>

        <div class="section">
            <h3>2. RGB 텍스트 ➡️ 사진 복원</h3>
            <p style="font-size: 13px; color: #666;">공유받은 압축 형식의 텍스트를 그대로 붙여넣으세요.</p>
            <textarea id="tngInput" placeholder="[W:X|H:Y]개수*(R,G,B),개수*(R,G,B)... 형태의 코드를 붙여넣으세요..."></textarea>
            <div id="restoreStatus" class="status"></div>
            <div class="btn-group">
                <button id="restoreBtn">이미지 복원하기</button>
                <button id="imageDownloadBtn" class="image-download-btn" disabled>이 사진 컴퓨터에 저장</button>
            </div>
            <br>
            <canvas id="restoreCanvas"></canvas>
        </div>
    </div>

    <script>
        const imageInput = document.getElementById('imageInput');
        const preview = document.getElementById('preview');
        const tngOutput = document.getElementById('tngOutput');
        const copyBtn = document.getElementById('copyBtn');
        const convertStatus = document.getElementById('convertStatus');
        
        const tngInput = document.getElementById('tngInput');
        const restoreBtn = document.getElementById('restoreBtn');
        const imageDownloadBtn = document.getElementById('imageDownloadBtn');
        const restoreCanvas = document.getElementById('restoreCanvas');
        const restoreStatus = document.getElementById('restoreStatus');

        // [기능 1] 이미지의 픽셀을 돌면서 연속된 같은 색상을 개수*(R,G,B) 형태로 압축 추출
        imageInput.addEventListener('change', function(e) {
            const file = e.target.files[0];
            if (!file) return;

            const reader = new FileReader();
            reader.onload = function(event) {
                preview.src = event.target.result;
                preview.style.display = 'block';

                const img = new Image();
                img.onload = function() {
                    const canvas = document.createElement('canvas');
                    const ctx = canvas.getContext('2d');
                    
                    const scale = Math.min(1, 300 / img.width);
                    canvas.width = Math.round(img.width * scale);
                    canvas.height = Math.round(img.height * scale);
                    
                    ctx.drawImage(img, 0, 0, canvas.width, canvas.height);
                    
                    const imgData = ctx.getImageData(0, 0, canvas.width, canvas.height);
                    const data = imgData.data; 
                    
                    convertStatus.innerText = `픽셀 압축 분석 중... (총 ${canvas.width * canvas.height}개 픽셀)`;

                    let compressedArray = [];
                    // 첫 번째 픽셀의 RGB 값으로 초기화
                    let currentRgb = `(${data[0]},${data[1]},${data[2]})`;
                    let count = 1;

                    // 두 번째 픽셀(i=4)부터 배열의 끝까지 순회
                    for (let i = 4; i < data.length; i += 4) {
                        const r = data[i];
                        const g = data[i+1];
                        const b = data[i+2];
                        const nextRgb = `(${r},${g},${b})`;

                        if (nextRgb === currentRgb) {
                            count++; // 색상이 같으면 개수 카운트 업
                        } else {
                            // 색상이 달라지면 지금까지 쌓인 픽셀을 개수*RGB 형태로 저장
                            compressedArray.push(`${count}*${currentRgb}`);
                            currentRgb = nextRgb; // 기준 색상 변경
                            count = 1; // 카운트 초기화
                        }
                    }
                    // 마지막 남은 픽셀 묶음 추가
                    compressedArray.push(`${count}*${currentRgb}`);

                    // 메타데이터 헤더와 합쳐서 최종 텍스트 생성
                    const finalTngText = `[W:${canvas.width}|H:${canvas.height}]` + compressedArray.join(',');
                    
                    tngOutput.value = finalTngText;
                    convertStatus.innerText = `압축 변환 완료! (텍스트 크기: ${(finalTngText.length / 1024).toFixed(1)} KB)`;
                    copyBtn.disabled = false;
                };
                img.src = event.target.result;
            };
            reader.readAsDataURL(file);
        });

        // 클립보드 복사
        copyBtn.addEventListener('click', function() {
            tngOutput.select();
            document.execCommand('copy');
            alert('TNG 압축 텍스트가 복사되었습니다! 일반 텍스트 게시판에 공유해 보세요.');
        });

        // [기능 2] 압축된 개수*(R,G,B) 텍스트를 해체해서 하나씩 찍어 복원
        restoreBtn.addEventListener('click', function() {
            const tngText = tngInput.value.trim();
            if (!tngText) {
                alert('TNG RGB 텍스트를 입력해주세요.');
                return;
            }

            try {
                restoreStatus.innerText = "텍스트 압축 해제 및 픽셀 복원 중...";

                // 1. 헤더에서 크기 정보 추출
                const headerMatch = tngText.match(/^\[W:(\d+)\|H:(\d+)\]/);
                if (!headerMatch) {
                    alert('올바른 TNG 형식이 아닙니다. 크기 정보([W:X|H:Y])가 누락되었습니다.');
                    restoreStatus.innerText = "";
                    return;
                }

                const width = parseInt(headerMatch[1]);
                const height = parseInt(headerMatch[2]);
                
                const dataPart = tngText.substring(headerMatch[0].length);
                
                // 2. 정규식으로 "숫자*(R,G,B)" 패턴들을 매칭해서 배열로 가져오기
                const pixelMatches = dataPart.match(/\d+\*\(\d+,\d+,\d+\)/g);
                if (!pixelMatches || pixelMatches.length === 0) {
                    alert('압축된 픽셀 데이터를 찾을 수 없거나 올바르지 않은 형식입니다.');
                    restoreStatus.innerText = "";
                    return;
                }

                restoreCanvas.width = width;
                restoreCanvas.height = height;
                const ctx = restoreCanvas.getContext('2d');
                const imgData = ctx.createImageData(width, height);
                const data = imgData.data;

                // 3. 압축 데이터를 순서대로 돌면서 개수만큼 픽셀 복원하기
                let dataIdx = 0;
                for (let i = 0; i < pixelMatches.length; i++) {
                    // "3*(255,255,255)" -> ["3", "(255,255,255)"]
                    const [countStr, rgbStr] = pixelMatches[i].split('*');
                    const count = parseInt(countStr);
                    
                    // "(255,255,255)" -> ["255", "255", "255"]
                    const rgbValues = rgbStr.replace(/[\(\)]/g, '').split(',');
                    const r = parseInt(rgbValues[0]);
                    const g = parseInt(rgbValues[1]);
                    const b = parseInt(rgbValues[2]);

                    // 저장되어 있던 count(개수)만큼 반복해서 RGBA 배열 채우기
                    for (let j = 0; j < count; j++) {
                        if (dataIdx >= data.length) break;
                        data[dataIdx]     = r;
                        data[dataIdx + 1] = g;
                        data[dataIdx + 2] = b;
                        data[dataIdx + 3] = 255; // Alpha
                        dataIdx += 4;
                    }
                }

                ctx.putImageData(imgData, 0, 0);
                restoreCanvas.style.display = 'block';
                restoreStatus.innerText = "복원 성공!";
                imageDownloadBtn.disabled = false;

            } catch (error) {
                alert('복원 실패! 데이터 압축 해제 중 에러 발생.');
                restoreStatus.innerText = "";
                console.error(error);
            }
        });

        // 다운로드 기능
        imageDownloadBtn.addEventListener('click', function() {
            const url = restoreCanvas.toDataURL('image/png');
            const a = document.createElement('a');
            a.href = url;
            a.download = 'tng_compressed_restored.png';
            document.body.appendChild(a);
            a.click();
            document.body.removeChild(a);
        });
    </script>
</body>
</html>
