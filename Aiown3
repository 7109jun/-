<script>
    // 테스트용 시나리오 데이터 자동 로드
    window.onload = function() {
        document.getElementById('mdInput').value = `# 프로젝트: Cryptos\n# 버전: 3.6\n# 업데이트일자: 2026-06-30\n# 활성화여부: true\n# 비고: null\n\n// 이 라인은 일반 주석입니다. 컴파일 시 필터링됩니다.\n\n## 1. 개요\n**Cryptos**는 독특한 **암호 언어**입니다!\n\n\`\`\`\nfunction test() {\n    console.log("Hello Aiwon Engine"); // 코드 내부 주석 보존 검증\n}\n\`\`\`\n\n## 2. 데이터 테이블 (상태 보존 검증)\n| 알파벳 | 기호값 | 분류 |\n|---|---|---|\n| a | ♋︎ | 기본기호 |\n| b | ♌︎ | 기본기호 |\n\n## 3. 리소스 링크\n상세 정보는 [메인 레포지토리](https://github.com/7109jun/cryptos)에서 확인이 가능하며, 예시 파일은 ![로고 이미지](logo.png) 항목을 참조바랍니다.`;
    };

    function compileToAiwon() {
        const input = document.getElementById('mdInput').value;
        const lines = input.split('\n');
        let output = [];
        let inCodeBlock = false;
        let codeContent = [];
        let inTable = false;
        let tableHeaders = [];
        let tableRows = [];

        // Greedy Matching 제어를 위한 경계 정규식 구성
        const imgRegex = /!\[(.*?)\]\((.*?)\)/g;              
        const urlRegex = /\[(.*?)\]\((https?:\/\/[^\s\)]+)\)/g; 
        const boldRegex = /\*\*(.*?)\*\*/g;                     
        const dateRegex = /^\d{4}-\d{2}-\d{2}$/;
        const boolRegex = /^(true|false)$/i;
        const nullRegex = /^(null)$/i;

        function parseValue(val) {
            if (boolRegex.test(val)) return `!${val}!`; 
            if (dateRegex.test(val)) return `$${val}$`; 
            if (nullRegex.test(val)) return `/null/`;   
            if (val.includes('(') || val.includes('{') || val.includes(';') || val.includes('"') || val.includes('=')) return `[${val}]`;
            if (!isNaN(val) && val.trim() !== '') return val; 
            return `<${val}>`; 
        }

        for (let i = 0; i < lines.length; i++) {
            let line = lines[i];

            // 코드 블록 우선 처리 장치 (주석 필터링 오작동 회피)
            if (line.trim().startsWith('```')) {
                if (!inCodeBlock) {
                    inCodeBlock = true;
                    codeContent = [];
                } else {
                    inCodeBlock = false;
                    output.push(`[\n${codeContent.join('\n')}\n]`);
                }
                continue;
            }
            if (inCodeBlock) {
                codeContent.push(line);
                continue;
            }

            if (line.trim().startsWith('//')) continue; 

            // 구조적 데이터(표) 파싱
            if (line.trim().startsWith('|')) {
                if (/^\|?[\s\-:|]+\|?$/.test(line.trim())) continue; 
                let cells = line.split('|').map(c => c.trim()).filter(c => c !== '');
                if (!inTable) {
                    inTable = true;
                    tableHeaders = cells;
                } else {
                    tableRows.push(cells);
                }
                continue; 
            } else {
                if (inTable) {
                    tableRows.forEach(row => {
                        let rowTokens = [];
                        tableHeaders.forEach((header, idx) => {
                            let val = row[idx] ? row[idx] : '';
                            rowTokens.push(`<${header}>=${parseValue(val)}`);
                        });
                        output.push(`| ${rowTokens.join(', ')} |`);
                    });
                    inTable = false; tableHeaders = []; tableRows = [];
                }
            }

            // 프론트 매터 및 메타데이터 파싱 균형화
            if (line.startsWith('#') && !line.startsWith('##') && line.includes(':')) {
                let parts = line.substring(1).split(':');
                let key = parts[0].trim();
                let val = parts.slice(1).join(':').trim();
                output.push(`# <${key}>=${parseValue(val)}`);
                continue;
            }

            // 인라인 정규식 파이프라인 연산 안정화
            line = line.replace(imgRegex, '~$1|$2~');
            line = line.replace(urlRegex, '@$1|$2@');
            line = line.replace(boldRegex, '%$1%');

            if (line.trim() !== '' || lines[i] === '') {
                output.push(line);
            }
        }

        if (inTable) {
            tableRows.forEach(row => {
                let rowTokens = [];
                tableHeaders.forEach((header, idx) => {
                    let val = row[idx] ? row[idx] : '';
                    rowTokens.push(`<${header}>=${parseValue(val)}`);
                });
                output.push(`| ${rowTokens.join(', ')} |`);
            });
        }

        document.getElementById('aiownOutput').value = output.join('\n');
    }

    function depileToMarkdown() {
        const input = document.getElementById('aiownOutput').value;
        const lines = input.split('\n');
        let output = [];
        let inCodeBlock = false;
        let tableBuffer = [];

        for (let i = 0; i < lines.length; i++) {
            let line = lines[i];

            if (line.trim() === '[') { inCodeBlock = true; output.push('```'); continue; }
            if (line.trim() === ']') { inCodeBlock = false; output.push('```'); continue; }
            if (inCodeBlock) { output.push(line); continue; }

            if (line.startsWith('# <') && line.includes('=')) {
                let match = line.match(/^# <([^>]+)>=(.*)$/);
                if (match) {
                    let key = match[1];
                    let val = match[2].trim();
                    val = val.replace(/[<>!$\/]/g, '').replace(/null/g, 'null');
                    output.push(`# ${key}: ${val}`);
                    continue;
                }
            }

            // 유실 없는 표 복원 매핑 엔진
            if (line.trim().startsWith('|') && line.trim().endsWith('|') && line.includes('>=')) {
                let content = line.trim().slice(1, -1); 
                let pairs = content.split(',').map(p => p.trim());
                
                if (tableBuffer.length === 0) {
                    let headers = pairs.map(p => p.split('>=')[0].replace(/[<>]/g, ''));
                    tableBuffer.push(`| ${headers.join(' | ')} |`);
                    tableBuffer.push(`| ${headers.map(() => '---').join(' | ')} |`);
                }
                
                let values = pairs.map(p => {
                    let val = p.split('>=')[1];
                    return val.replace(/[<>!$\/]/g, '').replace(/\[(.*?)\]/g, '$1');
                });
                tableBuffer.push(`| ${values.join(' | ')} |`);
                continue;
            } else {
                if (tableBuffer.length > 0) {
                    output.push(tableBuffer.join('\n'));
                    tableBuffer = [];
                }
            }

            // 결합 구조 해제 정규식 
            line = line.replace(/~(.*?)\|(.*?)~/g, '![$1]($2)'); 
            line = line.replace(/@(.*?)\|(.*?)@/g, '[$1]($2)'); 
            line = line.replace(/%(.*?)%/g, '**$1**');          
            
            // 토큰 기호 이스케이프 해제 및 순수 데이터 환원
            line = line.replace(/!(true|false)!/gi, '$1');
            line = line.replace(/\$([0-9]{4}-[0-9]{2}-[0-9]{2})\$/g, '$1');
            line = line.replace(/\/null\//g, 'null');
            line = line.replace(/<(.*?)>/g, '$1'); 
            line = line.replace(/\[(.*?)\]/g, '$1'); 

            output.push(line);
        }
        
        if (tableBuffer.length > 0) {
            output.push(tableBuffer.join('\n'));
        }
        
        document.getElementById('mdInput').value = output.join('\n');
    }
</script>
