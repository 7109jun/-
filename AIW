<script>
function convertJSONtoAIW() {
    const jsonInput = document.getElementById('json-input').value.trim();
    const aiwOutput = document.getElementById('aiw-output');
    const errorDiv = document.getElementById('error');
    
    errorDiv.style.display = 'none';
    aiwOutput.value = '';

    if (!jsonInput) {
        errorDiv.innerText = 'JSON 데이터를 입력해주세요.';
        errorDiv.style.display = 'block';
        return;
    }

    try {
        const parsedJson = JSON.parse(jsonInput);
        let result = "# AIW 포맷으로 자동 변환된 문서입니다.\n";
        
        // 데이터 구조 파싱 엔진 작동
        result += parseElement(parsedJson, 1, "");
        
        aiwOutput.value = result.trim();
    } catch (e) {
        errorDiv.innerText = '올바른 JSON 형식이 아닙니다: ' + e.message;
        errorDiv.style.display = 'block';
    }
}

function parseElement(obj, level, keyName) {
    let output = "";
    const indent = "  ".repeat(level - 1);

    // 1. Null 처리
    if (obj === null) {
        return `${indent}${keyName}$(0)$\n`;
    }

    // 2. 배열(Array) 처리
    if (Array.isArray(obj)) {
        if (keyName) {
            output += `${indent}${keyName}\n`;
        }
        obj.forEach(item => {
            if (typeof item === 'object' && item !== null) {
                output += `${indent}- (\n${parseElement(item, level + 1, "")}${indent})\n`;
            } else {
                output += `${indent}- ${formatValue(item)}\n`;
            }
        });
        return output;
    }

    // 3. 객체(Object) 처리
    if (typeof obj === 'object') {
        if (keyName) {
            const exclamation = "!".repeat(Math.min(level, 2));
            const cleanKey = keyName.replace(/[&:]/g, "").trim();
            output += `\n${indent}!(${cleanKey})${exclamation}\n\n`;
        }
        
        for (const key in obj) {
            const formattedKey = `&(${key})&: `;
            output += parseElement(obj[key], level + 1, formattedKey);
        }
        return output;
    }

    // 4. 일반 원시 값 처리
    return `${indent}${keyName}${formatValue(obj)}\n`;
}

function formatValue(val) {
    if (typeof val === 'string') {
        // 날짜 형식 판단 (YYYY-MM-DD 패턴 파악)
        const dateRegex = /^\d{4}-\d{2}-\d{2}/;
        if (dateRegex.test(val)) {
            const parts = val.split(/[-T:]/);
            return `+(${parts[0]}),(${parts[1]}),(${parts[2]})+`;
        }
        // 이미지 및 링크 형식 판단
        if (val.match(/\.(jpeg|jpg|gif|png|svg)$/i) || val.startsWith('http')) {
            if (val.includes('img') || val.match(/\.(jpeg|jpg|gif|png|svg)$/i)) {
                return `;(${val});`;
            }
        }
        return `@("${val}")@`;
    }
    if (typeof val === 'boolean') {
        return val ? "[1]" : "[0]";
    }
    return val;
}
