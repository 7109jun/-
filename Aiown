<body>

<div class="container">
    <header>
        <h1>⚡ Aiown v2.5 (AI-owned Document Format) Compiler</h1>
        <p>인간 중심의 Markdown 문서를 AI 최적화 초고속 파싱 포맷인 Aiown(.aiown)으로 컴파일합니다. <span class="badge">v2.5 Open Spec</span></p>
    </header>

    <div class="grid">
        <div class="card">
            <h2>📝 Human-Readable (Markdown Input)</h2>
            <textarea id="mdInput" placeholder="이곳에 마크다운 문서를 입력하세요..."></textarea>
        </div>
        <div class="card">
            <h2>🤖 AI-Readable (Aiown v2.5 Output)</h2>
            <textarea id="aiownOutput" readonly placeholder="컴파일된 Aiown 결과가 여기에 출력됩니다."></textarea>
        </div>
    </div>

    <div class="btn-center">
        <button onclick="compileToAiown()">🚀 Aiown 엔진으로 컴파일 실행</button>
    </div>

    <div class="spec-box">
        <h3>📐 Aiown v2.5 문법 명세 매핑 테이블 (Spec Summary)</h3>
        <table>
            <tr><th>기호 패턴</th><th>컴파일 타겟 구조</th><th>설명</th></tr>
            <tr><td><code>["값"]</code></td><td>URL / URI String</td><td>따옴표가 포함된 대괄호는 참조 외부 웹 링크 주소로 처리</td></tr>
            <tr><td><code>[값]</code></td><td>Age / Revision (Integer)</td><td>순수 숫자가 들어간 대괄호는 데이터의 수정 횟수 및 나이로 처리</td></tr>
            <tr><td><code>&lt;"값"&gt;</code></td><td>Name / Identifier</td><td>따옴표가 포함된 꺾쇠는 고유 명사, 식별자, 이름으로 처리</td></tr>
            <tr><td><code>&lt;값&gt;</code></td><td>Code / Script block</td><td>순수 텍스트는 실행 가능한 소스 코드 및 명령어로 분리</td></tr>
            <tr><td><code>@값@</code></td><td>Media Data Path</td><td>이미지 파일 경로 (.png, .jpg 등) 매핑</td></tr>
            <tr><td><code>~값~</code></td><td>High Priority Vector</td><td>AI RAG 시스템 가중치 최고 등급 지정 (중요 정보)</td></tr>
            <tr><td><code>,</code></td><td>Object Delimiter</td><td>단일 행 내부에서 데이터 객체 간 경계를 설정</td></tr>
        </table>
    </div>
</div>

<script>
    // 기본 샘플 템플릿 로드 (Cryptos 암호 언어 프로젝트 예시 탑재)
    window.onload = function() {
        document.getElementById('mdInput').value = `# 프로젝트: Cryptos\n# 버전: 3.6\n# 중요마일스톤: 2026-06-30 최종 업데이트 완료\n\n## 1. 개요\n**Cryptos**는 윙딩폰트(Wingdings Font)를 이용한 독특한 **암호 언어**입니다!\n\n\`\`\`\n예시: Hello\n↓\n📄︎🙧♏︎●︎□\n\`\`\`\n\n## 2. 기본 문자 변환 규칙\n| 알파벳 | 기호값 | 분류 |\n|---|---|---|\n| a | ♋︎ | 기본문자 |\n| b | ♌︎ | 기본문자 |\n| c | ♍︎ | 기본문자 |\n\n## 3. 리소스 및 자원 링크\n상세 정보는 메인 저장소인 https://github.com/7109jun/cryptos 에서 확인 가능합니다.\n\n![로고 이미지](logo.png)`;
    };

    function compileToAiown() {
        const input = document.getElementById('mdInput').value;
        const lines = input.split('\n');
        let output = [];
        let inCodeBlock = false;
        let codeContent = [];
        let inTable = false;
        let tableHeaders = [];
        let tableRows = [];

        for (let i = 0; i < lines.length; i++) {
            let line = lines[i].trim();

            // 1. 코드 블록 처리 (``` -> <코드>)
            if (line.startsWith('```')) {
                if (!inCodeBlock) {
                    inCodeBlock = true;
                    codeContent = [];
                } else {
                    inCodeBlock = false;
                    output.push(`* <코드> <\n${codeContent.join('\n')}\n>`);
                }
                continue;
            }
            if (inCodeBlock) {
                codeContent.push(lines[i]); // 원본 코드 보존
                continue;
            }

            // 2. 마크다운 표 처리 (| -> , 와 객체화)
            if (line.startsWith('|')) {
                if (line.includes('---') || line.includes(':-')) continue;
                let cells = line.split('|').map(c => c.trim()).filter(c => c !== '');
                if (!inTable) {
                    inTable = true;
                    tableHeaders = cells;
                } else {
                    tableRows.push(cells);
                }
                continue;
            } else {
                if (inTable) {
                    tableRows.forEach(row => {
                        let rowTokens = [];
                        tableHeaders.forEach((header, idx) => {
                            let val = row[idx] ? row[idx] : '';
                            // URL 검사 규칙 적용
                            if (val.startsWith('http')) {
                                rowTokens.push(`${header} ["${val}"]`);
                            } else if (!isNaN(val) && val !== '') { // 숫자(나이) 검사 규칙 적용
                                rowTokens.push(`${header} [${val}]`);
                            } else {
                                rowTokens.push(`${header} <"${val}">`);
                            }
                        });
                        output.push(`* ${rowTokens.join(', ')}`);
                    });
                    output.push('');
                    inTable = false; tableHeaders = []; tableRows = [];
                }
            }

            // 3. 메타데이터 생성 규칙 (# 구조화 및 , 결합)
            if (line.startsWith('#') && !line.startsWith('##')) {
                let content = line.replace(/^#\s*/, '');
                if (content.includes(':')) {
                    let parts = content.split(':');
                    let key = parts[0].trim();
                    let val = parts.slice(1).join(':').trim();
                    if (!isNaN(val)) {
                        output.push(`# ${key} [${val}]`);
                    } else {
                        output.push(`# ${key} <"${val}">`);
                    }
                } else {
                    output.push(line);
                }
                continue;
            }

            // 4. 인라인 요소 컴파일 (이미지 @, 중요 ~, URL [])
            // 이미지 처리: ![alt](path) -> @path@
            let imgRegex = /!\[.*?\]\((.*?)\)/g;
            line = line.replace(imgRegex, '@$1@');

            // 중요 정보 처리: **텍스트** -> ~텍스트~
            let boldRegex = /\*\*(.*?)\*\*/g;
            line = line.replace(boldRegex, '~$1~');

            // 본문 내 URL 처리 (독립 링크)
            let urlRegex = /(https?:\/\/[^\s]+)/g;
            line = line.replace(urlRegex, '["$1"]');

            if (line !== '') {
                output.push(line);
            } else if (lines[i] === '') {
                output.push('');
            }
        }

        // 잔여 표 데이터 마감
        if (inTable) {
            tableRows.forEach(row => {
                let rowTokens = [];
                tableHeaders.forEach((header, idx) => {
                    let val = row[idx] ? row[idx] : '';
                    if (val.startsWith('http')) rowTokens.push(`${header} ["${val}"]`);
                    else if (!isNaN(val) && val !== '') rowTokens.push(`${header} [${val}]`);
                    else rowTokens.push(`${header} <"${val}">`);
                });
                output.push(`* ${rowTokens.join(', ')}`);
            });
        }

        document.getElementById('aiownOutput').value = output.join('\n');
    }
</script>
</body>
</html>
