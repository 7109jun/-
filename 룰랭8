  html = html.replace(/"([^"]*)"/g, '<span class="tok-string">"$1"</span>');
  html = html.replace(/#[0-9a-fA-F]{3,6}\b/g, m => '<span class="tok-color">' + m + '</span>');
  html = html.replace(/\b(\d+(\.\d+)?)\b/g, '<span class="tok-number">$1</span>');
  html = html.replace(/(룰랄|아니면|루루|FUNCTION|END|CALL|SPRITE|SHAPE|ANIMATION|OBJECT|WALL|SET|RAM|CLEAR|RENDER|TEXT|MAP|ENDMAP|TOUCH|CAMERA|ISCOLLIDE|COLLIDE|FOLLOW|ZOOM|변수|리스트|클래스|필드|NEW|확장|THIS|MODE|ANGLE|반복|SOUND|릴리랄|재생|정지|부터|까지|초|IMAGE|PUSH|POP|BREAK|CONTINUE|복제|막기|DELETE|DELETEALL)/g, '<span class="tok-keyword">$1</span>');
  html = html.replace(/\b(RANDOM|ABS|MIN|MAX|FLOOR|ROUND|SQRT|SIN|COS|POW|CLAMP|ATAN2|LOG|EXP|LERP|DIST|PI|E)\b/g, '<span class="tok-type">$1</span>');
  html = html.replace(/\b(PLAYER|NPC|ENEMY|PROJECTILE|ITEM|CUSTOM)\b/g, '<span class="tok-type">$1</span>');
  return html;
}
