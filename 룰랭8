    return true;
  } catch (err) {
    const e = err instanceof LullangError ? err : new LullangError('COMPILE', err.message, '?', '문법을 다시 확인하세요.');
    pushProblem('error', e.errType, e.message, e.line, e.suggestion);
    consoleLog('err', '컴파일 실패 (Line ' + e.line + '): ' + e.message);
    return false;
  }
}

