  // 커서 근처에 위치시키기 (줄/컬럼 근사 계산 - 모노스페이스 폰트 기준)
  const rect = editorInput.getBoundingClientRect();
  const start = editorInput.selectionStart;
  const value = editorInput.value;
  const upToCursor = value.slice(0, start);
  const lineIndex = (upToCursor.match(/\n/g) || []).length;
  const lineStart = upToCursor.lastIndexOf('\n') + 1;
  const col = start - lineStart;
  const lineHeight = 20, charWidth = 7.5, gutterAndPad = 44 + 12;
  const top = rect.top + 10 + (lineIndex + 1) * lineHeight - editorInput.scrollTop;
  const left = rect.left + gutterAndPad + col * charWidth - editorInput.scrollLeft;
  autocompleteBox.style.top = Math.min(top, window.innerHeight - 40) + 'px';
  autocompleteBox.style.left = Math.min(left, window.innerWidth - 180) + 'px';
  autocompleteBox.style.display = 'block';
  autocompleteBox.querySelectorAll('.ac-item').forEach(el => {
    el.addEventListener('mousedown', (e) => { e.preventDefault(); applyAutocomplete(parseInt(el.dataset.i, 10)); });
  });
}
function hideAutocomplete() { autocompleteBox.style.display = 'none'; autocompleteMatches = []; }
function applyAutocomplete(idx) {
  const chosen = autocompleteMatches[idx]; if (!chosen) return;
  const start = editorInput.selectionStart;
  const value = editorInput.value;
  const lineStart = value.lastIndexOf('\n', start - 1) + 1;
  const prefixLen = value.slice(lineStart, start).replace(/^[ \t]+/, '').length;
  const replaceStart = start - prefixLen;
  editorInput.value = value.slice(0, replaceStart) + chosen + value.slice(start);
  editorInput.selectionStart = editorInput.selectionEnd = replaceStart + chosen.length;
  refreshEditorView(); LullangFS.save(editorInput.value);
  hideAutocomplete();
}

