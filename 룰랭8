   ========================================================================= */
// 도형은 -50..50 정규화 좌표계에 점을 찍고, 선/면으로 연결해서 만든다.
// 렌더링 시 오브젝트의 width/height 비율로 스케일되어 그려진다.
function parseLullangShapeRows(rawRows) {
  const points = [], lines = [], faces = [], circles = [], arcs = [];
  let currentWidth = 1;
  rawRows.forEach(raw => {
    const t = raw.trim();
    if (!t || t.startsWith('//')) return;
    const parts = t.split(/\s+/);
    if (parts[0] === '점') {
      points.push([parseFloat(parts[1]) || 0, parseFloat(parts[2]) || 0]);
    } else if (parts[0] === '굵기') {
      currentWidth = parseFloat(parts[1]) || 1;
    } else if (parts[0] === '선') {
      lines.push({ a: parseInt(parts[1], 10), b: parseInt(parts[2], 10), color: parts[3] || null, width: currentWidth });
    } else if (parts[0] === '면') {
      const indices = []; let color = null;
      for (let i = 1; i < parts.length; i++) {
        if (parts[i].startsWith('#')) color = parts[i];
        else indices.push(parseInt(parts[i], 10));
      }
      faces.push({ indices, color });
    } else if (parts[0] === '원') {
      // 원 cx cy 반지름 [color] [칠or테두리(채움/테두리)]
      circles.push({ cx: parseFloat(parts[1]) || 0, cy: parseFloat(parts[2]) || 0, r: parseFloat(parts[3]) || 0, color: parts[4] && parts[4].startsWith('#') ? parts[4] : null, filled: parts[5] !== '테두리', width: currentWidth });
    } else if (parts[0] === '호') {
      // 호 cx cy 반지름 시작각 끝각 [color]
      arcs.push({ cx: parseFloat(parts[1]) || 0, cy: parseFloat(parts[2]) || 0, r: parseFloat(parts[3]) || 0, start: parseFloat(parts[4]) || 0, end: parseFloat(parts[5]) || 0, color: parts[6] || null, width: currentWidth });
    }
  });
  return { points, lines, faces, circles, arcs };
}
