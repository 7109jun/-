    const objs = LullangObjectManager.all().filter(o => {
      if (!o.visible || !o.active) return false;
      // 뷰포트 컬링(최적화): 화면 영역 밖(여유 64px)에 있으면 그리지 않고 건너뜀
      const sx = o.x - LullangCamera.x, sy = o.y - LullangCamera.y;
      return sx + o.width > -64 && sx < cw + 64 && sy + o.height > -64 && sy < ch + 64;
    }).sort((a, b) => (a.layer - b.layer) || (a.y - b.y));
    objs.forEach(o => this.drawObject(o));
    this.textQueue.forEach(cmd => {
      this.ctx.fillStyle = '#d4d4d4';
      this.ctx.font = '11px monospace';
      this.ctx.fillText(cmd.text, cmd.x - LullangCamera.x, cmd.y - LullangCamera.y);
    });
  }
  // 둠(초창기) 스타일 레이캐스팅 3D 렌더러. MAP의 '#' 벽을 광선 행진(ray marching)으로 투영하고,
  // 다른 오브젝트는 빌보드(항상 카메라를 향하는 평면 스프라이트)로 그린다.
  flush3D() {
    const ctx = this.ctx, canvas = this.canvas;
    const w = canvas.width, h = canvas.height;
    const followObj = LullangCamera.followId ? LullangObjectManager.get(LullangCamera.followId) : null;
    const px = followObj ? followObj.x + followObj.width / 2 : 0;
    const py = followObj ? followObj.y + followObj.height / 2 : 0;
    const angleRad = (LullangCamera.angle || 0) * Math.PI / 180;
    const fovRad = 66 * Math.PI / 180;

    ctx.fillStyle = '#15151c'; ctx.fillRect(0, 0, w, h / 2);
    ctx.fillStyle = '#232323'; ctx.fillRect(0, h / 2, w, h / 2);

    const tileSize = LullangTileManager.tileSize;
    const rows = LullangTileManager.rows;
    const maxDist = tileSize * 24;
    const projDist = (w / 2) / Math.tan(fovRad / 2);
    const zBuffer = new Array(w).fill(maxDist);

    if (rows && rows.length) {
      const posX = px / tileSize, posY = py / tileSize;
      for (let col = 0; col < w; col++) {
        const rayAngle = angleRad - fovRad / 2 + (col / w) * fovRad;
        const rdx = Math.cos(rayAngle), rdy = Math.sin(rayAngle);
        // DDA: 픽셀 단위로 행진하지 않고 타일 경계만 건너뛰므로 훨씬 빠르다 (최적화)
        let mapX = Math.floor(posX), mapY = Math.floor(posY);
        const deltaDistX = rdx === 0 ? 1e30 : Math.abs(1 / rdx);
        const deltaDistY = rdy === 0 ? 1e30 : Math.abs(1 / rdy);
        let stepX, stepY, sideDistX, sideDistY;
        if (rdx < 0) { stepX = -1; sideDistX = (posX - mapX) * deltaDistX; } else { stepX = 1; sideDistX = (mapX + 1 - posX) * deltaDistX; }
        if (rdy < 0) { stepY = -1; sideDistY = (posY - mapY) * deltaDistY; } else { stepY = 1; sideDistY = (mapY + 1 - posY) * deltaDistY; }
        let hit = false, side = 0, guard = 0;
        while (!hit && guard < 80) {
          guard++;
          if (sideDistX < sideDistY) { sideDistX += deltaDistX; mapX += stepX; side = 0; }
          else { sideDistY += deltaDistY; mapY += stepY; side = 1; }
          const rowStr = rows[mapY];
          if (!rowStr || mapX < 0 || mapX >= rowStr.length || rowStr[mapX] === '#') hit = true;
        }
        const perpDistTiles = side === 0 ? (sideDistX - deltaDistX) : (sideDistY - deltaDistY);
        const correctedDist = Math.max(1, perpDistTiles * tileSize);
        zBuffer[col] = correctedDist;
        const wallHeight = Math.min(h, (tileSize * projDist) / correctedDist);
        const shade = Math.max(0.15, 1 - correctedDist / maxDist) * (side === 1 ? 0.75 : 1); // Y면은 살짝 더 어둡게(입체감)
        const rC = Math.floor(90 * shade) + 40, gC = Math.floor(90 * shade) + 40, bC = Math.floor(110 * shade) + 50;
        ctx.fillStyle = 'rgb(' + rC + ',' + gC + ',' + bC + ')';
        ctx.fillRect(col, (h - wallHeight) / 2, 1, wallHeight);
      }
    }

    // 빌보드 스프라이트: 벽이 아닌 오브젝트를 거리 역순(먼 것부터)으로 그려서 자연스러운 겹침을 만든다
    const objs = LullangObjectManager.all().filter(o => o.visible && o.active && o.type !== 'WALL' && o.id !== LullangCamera.followId);
    const billboards = objs.map(o => {
      const ocx = o.x + o.width / 2, ocy = o.y + o.height / 2;
      const ddx = ocx - px, ddy = ocy - py;
      const dist = Math.sqrt(ddx * ddx + ddy * ddy);
      let angleToObj = Math.atan2(ddy, ddx) - angleRad;
      while (angleToObj > Math.PI) angleToObj -= Math.PI * 2;
      while (angleToObj < -Math.PI) angleToObj += Math.PI * 2;
      return { o, dist, angleToObj };
    }).filter(b => Math.abs(b.angleToObj) < fovRad / 2 + 0.3 && b.dist > 1)
      .sort((a, b) => b.dist - a.dist);

    billboards.forEach(b => {
      const screenX = (0.5 + b.angleToObj / fovRad) * w;
      const size = Math.min(h, (tileSize * projDist) / b.dist) * (b.o.width / tileSize);
      const colIndex = Math.max(0, Math.min(w - 1, Math.floor(screenX)));
      if (b.dist > zBuffer[colIndex]) return; // 벽 뒤에 있으면 그리지 않음(단순 오클루전)
      if (b.o.sprite && LullangSpriteManager.get(b.o.sprite)) {
        LullangSpriteManager.draw(ctx, b.o.sprite, screenX - size / 2, (h - size) / 2, Math.max(1, Math.floor(size / 6)));
      } else {
        ctx.fillStyle = b.o.color;
        ctx.fillRect(screenX - size / 2, (h - size) / 2, size, size);
      }
    });

    // HUD 텍스트는 카메라 오프셋 없이 화면 좌표 그대로 표시
    this.textQueue.forEach(cmd => {
      ctx.fillStyle = '#ffffff'; ctx.font = '11px monospace';
      ctx.fillText(cmd.text, cmd.x, cmd.y);
    });
  }
  drawObject(o) {
    const ctx = this.ctx;
    const sx = o.x - LullangCamera.x, sy = o.y - LullangCamera.y;
    ctx.save();
    ctx.translate(sx + o.width / 2, sy + o.height / 2);
    ctx.rotate((o.angle || 0) * Math.PI / 180);
    ctx.scale(o.scale || 1, o.scale || 1);
    const shapeData = o.shape ? LullangShapeManager.get(o.shape) : null;
    const loadedImage = o.image ? LullangImageManager.get(o.image) : null;
    if (loadedImage) {
      ctx.drawImage(loadedImage, -o.width / 2, -o.height / 2, o.width, o.height);
    } else if (shapeData) {
      this.drawShape(ctx, shapeData, o);
    } else if (o.pixelart && LullangPixelArtManager.get(o.pixelart)) {
      LullangPixelArtManager.draw(ctx, o.pixelart, -o.width / 2, -o.height / 2, o.width, o.height);
    } else if (o.animation && LullangAnimationManager.get(o.animation)) {
      const spriteName = LullangAnimationManager.currentSprite(o.animation, o.animStartTime, performance.now());
      if (spriteName && LullangSpriteManager.get(spriteName)) {
        LullangSpriteManager.draw(ctx, spriteName, -o.width / 2, -o.height / 2, Math.max(2, Math.floor(o.width / 6)));
      } else { ctx.fillStyle = o.color; ctx.fillRect(-o.width / 2, -o.height / 2, o.width, o.height); }
    } else if (o.sprite && LullangSpriteManager.get(o.sprite)) {
      LullangSpriteManager.draw(ctx, o.sprite, -o.width / 2, -o.height / 2, Math.max(2, Math.floor(o.width / 6)));
    } else {
      ctx.fillStyle = o.color;
      ctx.fillRect(-o.width / 2, -o.height / 2, o.width, o.height);
    }
    ctx.restore();
  }
  // 도형 데이터(점/선/면/원/호)를 -50..50 정규화 좌표계에서 오브젝트 크기에 맞게 스케일해서 그린다
  drawShape(ctx, shape, o) {
    const sx = o.width / 100, sy = o.height / 100;
    const px = (x) => x * sx, py = (y) => y * sy;
    shape.faces.forEach(f => {
      if (f.indices.length < 3) return;
      ctx.beginPath();
      f.indices.forEach((idx, i) => {
        const p = shape.points[idx]; if (!p) return;
        const X = px(p[0]), Y = py(p[1]);
        if (i === 0) ctx.moveTo(X, Y); else ctx.lineTo(X, Y);
      });
      ctx.closePath();
      ctx.fillStyle = f.color || o.color;
      ctx.fill();
    });
    (shape.circles || []).forEach(c => {
      ctx.beginPath();
      ctx.ellipse(px(c.cx), py(c.cy), Math.abs(px(c.r)), Math.abs(py(c.r)), 0, 0, Math.PI * 2);
      if (c.filled) { ctx.fillStyle = c.color || o.color; ctx.fill(); }
      else { ctx.strokeStyle = c.color || o.color; ctx.lineWidth = c.width || 1; ctx.stroke(); }
    });
    (shape.arcs || []).forEach(a => {
      ctx.beginPath();
      ctx.ellipse(px(a.cx), py(a.cy), Math.abs(px(a.r)), Math.abs(py(a.r)), 0, a.start * Math.PI / 180, a.end * Math.PI / 180);
      ctx.strokeStyle = a.color || o.color;
      ctx.lineWidth = a.width || 1;
      ctx.stroke();
    });
    shape.lines.forEach(l => {
      const a = shape.points[l.a], b = shape.points[l.b];
      if (!a || !b) return;
      ctx.beginPath();
      ctx.moveTo(px(a[0]), py(a[1]));
      ctx.lineTo(px(b[0]), py(b[1]));
      ctx.strokeStyle = l.color || o.color;
      ctx.lineWidth = l.width || 1;
      ctx.stroke();
    });
  }
}

/* =========================================================================
   11. STATEMENT PARSER (line-based, brace-aware) -> program AST
   ========================================================================= */
// 괄호 깊이를 추적하며 최상위 콤마 기준으로만 분리 (리스트 리터럴, 함수 인자 등에 사용)
function splitTopLevelCommas(s) {
  const out = []; let depth = 0, cur = '';
  for (let i = 0; i < s.length; i++) {
    const c = s[i];
    if (c === '(' || c === '[') depth++;
    else if (c === ')' || c === ']') depth--;
    if (c === ',' && depth === 0) { out.push(cur); cur = ''; }
    else cur += c;
  }
  if (cur.trim().length > 0 || out.length > 0) out.push(cur);
  return out;
}

class LullangStatementParser {
  constructor(sourceText) { this.lines = sourceText.replace(/\r\n/g, '\n').split('\n'); this.idx = 0; }
  peekLine() { return this.idx < this.lines.length ? this.lines[this.idx] : null; }
  nextLine() { return this.lines[this.idx++]; }

  parseProgram() {
    const stmts = [];
    while (this.idx < this.lines.length) {
      const raw = this.peekLine();
      if (raw === null) break;
      const trimmed = raw.trim();
      if (trimmed === '' || trimmed.startsWith('//') || trimmed.startsWith('/:')) { this.idx++; continue; }
      if (trimmed.startsWith('}')) break;
      stmts.push(this.parseStatement());
    }
    return stmts;
  }

  parseBlock() {
    const body = this.parseProgram();
    if (this.idx >= this.lines.length) throw new LullangError('SYNTAX', '블록이 "}" 로 닫히지 않았습니다.', this.idx + 1, '중괄호 짝을 맞춰주세요.');
    const trimmed = this.lines[this.idx].trim();
    if (!trimmed.startsWith('}')) throw new LullangError('SYNTAX', '블록이 "}" 로 닫히지 않았습니다.', this.idx + 1, '중괄호 짝을 맞춰주세요.');
    const remainder = trimmed.slice(1).trim();
    if (remainder.length > 0) this.lines[this.idx] = remainder;
    else this.idx++;
    return body;
  }

  parseIfHeader(line, lineNo) {
    const m = line.match(/^(?:룰랄|IF)\s+(.+)\s*\{$/);
    if (!m) throw new LullangError('SYNTAX', '룰랄 <조건> { (또는 IF <조건> {) 형식이 필요합니다.', lineNo, '예: 룰랄 RAM[0] == 0 { 또는 IF RAM[0] == 0 {');
    const condExpr = parseLullangExpression(m[1]);
    const thenBody = this.parseBlock();
    let elseBody = null;
    const after = this.peekLine();
    if (after !== null && /^(아니면|ELSE)\b/.test(after.trim())) {
      const elseLineNo = this.idx + 1;
      const elseLine = this.nextLine().trim();
      if (elseLine === '아니면 {' || elseLine === 'ELSE {') elseBody = this.parseBlock();
      else if (/^(아니면|ELSE)\s+(룰랄|IF)/.test(elseLine)) elseBody = [this.parseIfHeader(elseLine.replace(/^(아니면|ELSE)\s+/, ''), elseLineNo)];
      else throw new LullangError('SYNTAX', '"아니면"/"ELSE" 또는 "아니면 룰랄"/"ELSE IF" 형식이 필요합니다.', elseLineNo, '예: } 아니면 { 또는 } ELSE {');
    }
    return { type: 'if', condExpr, thenBody, elseBody, line: lineNo };
  }

  parseStatement() {
    const lineNo = this.idx + 1;
    const raw = this.nextLine();
    const line = raw.trim();

    if (line === 'MAP') {
      const rows = [];
      while (this.peekLine() !== null && this.peekLine().trim() !== 'ENDMAP') rows.push(this.nextLine());
      if (this.peekLine() === null) throw new LullangError('SYNTAX', 'MAP 블록이 ENDMAP으로 닫히지 않았습니다.', lineNo, 'ENDMAP을 추가하세요.');
      this.nextLine();
      return { type: 'map', rows, line: lineNo };
    }
    if (line === 'CLEAR') return { type: 'clear', line: lineNo };
    if (line === 'RENDER') return { type: 'render', line: lineNo };
    if (line.startsWith('TEXT ')) {
      const strMatch = line.match(/^TEXT\s+(\S+)\s+(\S+)\s+"(.*)"$/);
      if (strMatch) return { type: 'text', xExpr: parseLullangExpression(strMatch[1]), yExpr: parseLullangExpression(strMatch[2]), text: strMatch[3], valueExpr: null, line: lineNo };
      // 따옴표가 없으면 세 번째 인자를 식(expression)으로 해석한다. 예: TEXT 30 50 (a+5)
      const exprMatch = line.match(/^TEXT\s+(\S+)\s+(\S+)\s+(.+)$/);
      if (!exprMatch) throw new LullangError('SYNTAX', 'TEXT 문법 오류', lineNo, 'TEXT x y "문자열" 또는 TEXT x y (식) 형태여야 합니다.');
      return { type: 'text', xExpr: parseLullangExpression(exprMatch[1]), yExpr: parseLullangExpression(exprMatch[2]), text: null, valueExpr: parseLullangExpression(exprMatch[3]), line: lineNo };
    }
    // IMAGE 이름 "url_또는_data URI"  -> PNG/JPG 오브젝트 이미지 등록
    if (line.startsWith('IMAGE ')) {
      const m = line.match(/^IMAGE\s+(\S+)\s+"(.*)"$/);
      if (!m) throw new LullangError('SYNTAX', 'IMAGE 이름 "url" 형식이 필요합니다.', lineNo, '예: IMAGE hero "data:image/png;base64,..."');
      return { type: 'image_load', name: m[1], url: m[2], line: lineNo };
    }
    // SOUND 이름 "url_또는_data URI"  -> 이름 있는 사운드 등록 (mp3/wav/ogg 등, data: URI 포함)
    if (line.startsWith('SOUND ')) {
      const m = line.match(/^SOUND\s+(\S+)\s+"(.*)"$/);
      if (!m) throw new LullangError('SYNTAX', 'SOUND 이름 "url" 형식이 필요합니다.', lineNo, '예: SOUND jump "https://.../jump.mp3"');
      return { type: 'sound_load', name: m[1], url: m[2], line: lineNo };
    }
    // 릴리랄 이름 [N초[부터]] [M초까지] 재생 / 릴리랄 이름 정지
    if (line.startsWith('릴리랄 ')) {
      const rest = line.slice('릴리랄 '.length).trim();
      let m;
      if ((m = rest.match(/^(\S+)\s+정지$/))) return { type: 'sound_stop', name: m[1], line: lineNo };
      if ((m = rest.match(/^(\S+)\s+(\d+(?:\.\d+)?)\s*초\s*부터\s*(\d+(?:\.\d+)?)\s*초\s*까지\s*재생$/))) return { type: 'sound_play', name: m[1], fromExpr: parseLullangExpression(m[2]), toExpr: parseLullangExpression(m[3]), line: lineNo };
      if ((m = rest.match(/^(\S+)\s+(\d+(?:\.\d+)?)\s*초\s*부터\s*재생$/))) return { type: 'sound_play', name: m[1], fromExpr: parseLullangExpression(m[2]), toExpr: null, line: lineNo };
      if ((m = rest.match(/^(\S+)\s+(\d+(?:\.\d+)?)\s*초\s*까지\s*재생$/))) return { type: 'sound_play', name: m[1], fromExpr: null, toExpr: parseLullangExpression(m[2]), line: lineNo };
      if ((m = rest.match(/^(\S+)\s+(\d+(?:\.\d+)?)\s*초\s*재생$/))) return { type: 'sound_play', name: m[1], fromExpr: null, toExpr: parseLullangExpression(m[2]), line: lineNo };
      if ((m = rest.match(/^(\S+)\s+재생$/))) return { type: 'sound_play', name: m[1], fromExpr: null, toExpr: null, line: lineNo };
      throw new LullangError('SYNTAX', '릴리랄 문법 오류: "' + rest + '"', lineNo, '예: 릴리랄 jump 재생 / 릴리랄 jump 5초 재생 / 릴리랄 jump 2초부터 8초까지 재생 / 릴리랄 jump 정지');
    }
    if (line === 'BREAK') return { type: 'loop_break', line: lineNo };
    if (line === 'CONTINUE') return { type: 'loop_continue', line: lineNo };
    // 복제 원본id  -> 오브젝트의 복제본을 만든다 (이름: 원본id의복제본1, 원본id의복제본2, ...)
    if (line.startsWith('복제 ')) {
      const m = line.match(/^복제\s+(\S+)$/);
      if (!m) throw new LullangError('SYNTAX', '복제 원본id 형식이 필요합니다.', lineNo, '예: 복제 player');
      return { type: 'duplicate_object', sourceId: m[1], line: lineNo };
    }
    // DELETE id / DELETEALL 타입  -> 오브젝트 하나 삭제 / 특정 타입 전체 삭제 (복제본 정리에 사용)
    if (line.startsWith('DELETEALL ')) {
      const m = line.match(/^DELETEALL\s+(\S+)$/);
      if (!m) throw new LullangError('SYNTAX', 'DELETEALL 타입 형식이 필요합니다.', lineNo, '예: DELETEALL BULLET');
      return { type: 'delete_all_by_type', objType: m[1], line: lineNo };
    }
    if (line.startsWith('DELETE ')) {
      const m = line.match(/^DELETE\s+(\S+)$/);
      if (!m) throw new LullangError('SYNTAX', 'DELETE id 형식이 필요합니다.', lineNo, '예: DELETE bullet1');
      return { type: 'delete_object', id: m[1], line: lineNo };
    }
    // 막기 idA idB  -> 두 오브젝트가 겹쳐 있으면 가장 짧은 축으로 밀어내서 실제로 부딪히는 것처럼 만든다
    if (line.startsWith('막기 ')) {
      const m = line.match(/^막기\s+(\S+)\s+(\S+)$/);
      if (!m) throw new LullangError('SYNTAX', '막기 idA idB 형식이 필요합니다.', lineNo, '예: 막기 player wall1');
      return { type: 'solid_block', idA: m[1], idB: m[2], line: lineNo };
    }
    if (line.startsWith('WALL ')) {
      const parts = line.split(/\s+/).slice(1);
      if (parts.length < 4) throw new LullangError('SYNTAX', 'WALL x y w h 형식이 필요합니다.', lineNo, 'WALL 10 10 20 20');
      return { type: 'wall', xExpr: parseLullangExpression(parts[0]), yExpr: parseLullangExpression(parts[1]), wExpr: parseLullangExpression(parts[2]), hExpr: parseLullangExpression(parts[3]), line: lineNo };
    }
    if (line.startsWith('OBJECT ')) {
      const parts = line.split(/\s+/).slice(1);
      if (parts.length < 6) throw new LullangError('SYNTAX', 'OBJECT id TYPE x y w h [color] 형식이 필요합니다.', lineNo, '예: OBJECT 1 PLAYER 10 10 20 20 #4da3ff');
      return { type: 'object', id: parts[0], objType: parts[1], xExpr: parseLullangExpression(parts[2]), yExpr: parseLullangExpression(parts[3]), wExpr: parseLullangExpression(parts[4]), hExpr: parseLullangExpression(parts[5]), color: parts[6] || null, line: lineNo };
    }
    if (line.startsWith('SET ')) {
      const rest = line.slice(4).trim();
      const ramMatch = rest.match(/^RAM\[(.+?)\]\s*=?\s*(.+)$/);
      if (ramMatch) return { type: 'set_ram', indexExpr: parseLullangExpression(ramMatch[1]), valueExpr: parseLullangExpression(ramMatch[2]), line: lineNo };
      // SET name[idx] value  -> 리스트 원소 대입
      const listSetMatch = rest.match(/^(\S+)\[(.+?)\]\s*=?\s*(.+)$/);
      if (listSetMatch) return { type: 'list_set', name: listSetMatch[1], indexExpr: parseLullangExpression(listSetMatch[2]), valueExpr: parseLullangExpression(listSetMatch[3]), line: lineNo };
      // SET target.field value  -> OOP 필드 대입 (THIS.field 포함)
      const fieldSetMatch = rest.match(/^([A-Za-z0-9_가-힣]+)\.([A-Za-z0-9_가-힣]+)\s+(.+)$/);
      if (fieldSetMatch) return { type: 'field_set', target: fieldSetMatch[1], field: fieldSetMatch[2], valueExpr: parseLullangExpression(fieldSetMatch[3]), line: lineNo };
      const parts = rest.split(/\s+/);
      const id = parts[0], prop = parts[1], rawValue = parts.slice(2).join(' ');
      const numericProps = ['X', 'Y', 'WIDTH', 'HEIGHT', 'SIZE', 'ANGLE', 'SCALE', 'VISIBLE', 'ACTIVE', 'LAYER'];
      if (numericProps.includes((prop || '').toUpperCase())) return { type: 'set_prop', id, prop, valueExpr: parseLullangExpression(rawValue), rawValue: null, line: lineNo };
      return { type: 'set_prop', id, prop, valueExpr: null, rawValue, line: lineNo };
    }
    // 변수 a는 5   -> 이름 있는 변수 선언/갱신 (사용 전 반드시 선언해야 함)
    if (line.startsWith('변수 ')) {
      const m = line.match(/^변수\s+(\S+?)\s*(?:는|은)\s+(.+)$/);
      if (!m) throw new LullangError('SYNTAX', '변수 <이름>는 <식> 형식이 필요합니다.', lineNo, '예: 변수 a는 5');
      return { type: 'var_decl', name: m[1], valueExpr: parseLullangExpression(m[2]), line: lineNo };
    }
    // 리스트 arr는 [1, 2, 3]  -> 이름 있는 리스트 선언 (사용 전 반드시 선언해야 함)
    if (line.startsWith('리스트 ')) {
      const m = line.match(/^리스트\s+(\S+?)\s*(?:는|은)\s*\[(.*)\]$/);
      if (!m) throw new LullangError('SYNTAX', '리스트 <이름>는 [값, 값, ...] 형식이 필요합니다.', lineNo, '예: 리스트 arr는 [1, 2, 3]');
      const inner = m[2].trim();
      const itemExprs = inner.length === 0 ? [] : splitTopLevelCommas(inner).map(s => parseLullangExpression(s.trim()));
      return { type: 'list_decl', name: m[1], itemExprs, line: lineNo };
    }
    // PUSH 리스트 값  / POP 리스트   -> 리스트 끝에 추가 / 마지막 원소 제거
    if (line.startsWith('PUSH ')) {
      const m = line.match(/^PUSH\s+(\S+)\s+(.+)$/);
      if (!m) throw new LullangError('SYNTAX', 'PUSH 리스트이름 값 형식이 필요합니다.', lineNo, '예: PUSH arr 42');
      return { type: 'list_push', name: m[1], valueExpr: parseLullangExpression(m[2]), line: lineNo };
    }
    if (line.startsWith('POP ')) {
      const m = line.match(/^POP\s+(\S+)$/);
      if (!m) throw new LullangError('SYNTAX', 'POP 리스트이름 형식이 필요합니다.', lineNo, '예: POP arr');
      return { type: 'list_pop', name: m[1], line: lineNo };
    }
    // 클래스 이름 [확장 부모] { ... }  -> 필드 기본값 + 메서드(루루 FUNCTION)를 담는 OOP 클래스 정의
    if (line.startsWith('클래스 ')) {
      const m = line.match(/^클래스\s+(\S+)(?:\s+확장\s+(\S+))?\s*\{$/);
      if (!m) throw new LullangError('SYNTAX', '클래스 <이름> [확장 <부모>] { 형식이 필요합니다.', lineNo, '예: 클래스 Enemy { 또는 클래스 Zombie 확장 Enemy {');
      const body = this.parseProgram();
      const closeLine = this.peekLine();
      if (closeLine === null || closeLine.trim() !== '}') throw new LullangError('SYNTAX', '클래스 블록이 "}" 로 닫히지 않았습니다.', lineNo, '클래스 본문 끝에 } 를 추가하세요.');
      this.nextLine();
      return { type: 'class_def', name: m[1], parent: m[2] || null, body, line: lineNo };
    }
    // 필드 이름 = 식   -> 클래스 안에서 쓰는 필드 기본값 선언
    if (line.startsWith('필드 ')) {
      const m = line.match(/^필드\s+(\S+?)\s*=\s*(.+)$/);
      if (!m) throw new LullangError('SYNTAX', '필드 <이름> = <식> 형식이 필요합니다.', lineNo, '예: 필드 hp = 100');
      return { type: 'field_def', name: m[1], valueExpr: parseLullangExpression(m[2]), line: lineNo };
    }
    // NEW ClassName id x y w h [color]  -> 클래스로부터 오브젝트 인스턴스 생성 (필드 기본값 상속 포함)
    if (line.startsWith('NEW ')) {
      const parts = line.split(/\s+/).slice(1);
      if (parts.length < 6) throw new LullangError('SYNTAX', 'NEW ClassName id x y w h [color] 형식이 필요합니다.', lineNo, '예: NEW Enemy e1 100 100 16 16 #f2585a');
      return { type: 'new_object', className: parts[0], id: parts[1], xExpr: parseLullangExpression(parts[2]), yExpr: parseLullangExpression(parts[3]), wExpr: parseLullangExpression(parts[4]), hExpr: parseLullangExpression(parts[5]), color: parts[6] || null, line: lineNo };
    }
    if (line.startsWith('CAMERA ')) {
      const parts = line.split(/\s+/).slice(1);
      if (parts[0] === 'FOLLOW') return { type: 'camera_follow', id: parts[1], line: lineNo };
      if (parts[0] === 'X') return { type: 'camera_axis', axis: 'X', valueExpr: parseLullangExpression(parts[1]), line: lineNo };
      if (parts[0] === 'Y') return { type: 'camera_axis', axis: 'Y', valueExpr: parseLullangExpression(parts[1]), line: lineNo };
      if (parts[0] === 'ZOOM') return { type: 'camera_zoom', valueExpr: parseLullangExpression(parts[1]), line: lineNo };
      if (parts[0] === 'MODE') return { type: 'camera_mode', mode: parts[1], line: lineNo };
      if (parts[0] === 'ANGLE') return { type: 'camera_angle', valueExpr: parseLullangExpression(parts.slice(1).join(' ')), line: lineNo };
      throw new LullangError('SYNTAX', '알 수 없는 CAMERA 명령: ' + parts[0], lineNo, 'FOLLOW/X/Y/ZOOM/MODE/ANGLE 중 하나를 사용하세요.');
    }
    if (line.startsWith('TOUCH ')) {
      const m = line.match(/^TOUCH\s+(\S+)\s+(\S+)\s*\{$/);
      if (!m) throw new LullangError('SYNTAX', 'TOUCH typeA typeB { 형식이 필요합니다.', lineNo, '예: TOUCH PLAYER ENEMY {');
      const body = this.parseBlock();
      return { type: 'touch', typeA: m[1], typeB: m[2], body, line: lineNo };
    }
    if (line.startsWith('룰랄 ') || line.startsWith('IF ')) return this.parseIfHeader(line, lineNo);
    if (line.startsWith('루루 FUNCTION ')) {
      const name = line.slice('루루 FUNCTION '.length).replace(/\{$/, '').trim();
      const body = this.parseProgram();
      const closeBraceLine = this.peekLine();
      if (closeBraceLine === null || closeBraceLine.trim() !== '}') throw new LullangError('SYNTAX', '함수 블록이 "}" 로 닫히지 않았습니다.', lineNo, '함수 본문 바로 뒤에 } 줄을 추가하세요.');
      this.nextLine(); // '}' 소비 (이전 버전은 이 줄을 소비하지 않아 항상 컴파일이 깨졌음)
      const endLine = this.nextLine();
      if (!endLine || endLine.trim() !== '루루 END') throw new LullangError('SYNTAX', '함수가 "루루 END" 로 닫히지 않았습니다.', lineNo, '} 다음 줄에 루루 END를 추가하세요.');
      return { type: 'func_def', name, body, line: lineNo };
    }
    if (line.startsWith('루루 CALL ')) return { type: 'func_call', name: line.slice('루루 CALL '.length).trim(), line: lineNo };
    if (line.startsWith('루루 SPRITE ')) {
      const name = line.slice('루루 SPRITE '.length).replace(/\{$/, '').trim();
      const rows = [];
      while (this.peekLine() !== null && this.peekLine().trim() !== '}') rows.push(this.nextLine());
      if (this.peekLine() === null) throw new LullangError('SYNTAX', 'SPRITE 블록이 "}" 로 닫히지 않았습니다.', lineNo, '스프라이트 끝에 }를 추가하세요.');
      this.nextLine();
      return { type: 'sprite_def', name, rows, line: lineNo };
    }
    // 루루 SHAPE 이름 { 점/선/면/원/호/굵기 ... }  -> 커스텀 벡터 도형 정의
    if (line.startsWith('루루 SHAPE ')) {
      const name = line.slice('루루 SHAPE '.length).replace(/\{$/, '').trim();
      const rawRows = [];
      while (this.peekLine() !== null && this.peekLine().trim() !== '}') rawRows.push(this.nextLine());
      if (this.peekLine() === null) throw new LullangError('SYNTAX', 'SHAPE 블록이 "}" 로 닫히지 않았습니다.', lineNo, '도형 정의 끝에 }를 추가하세요.');
      this.nextLine();
      return { type: 'shape_def', name, rawRows, line: lineNo };
    }
    // 루루 PIXELART 이름 W H { 픽셀 x y r g b ... }  -> RGB 그물망으로 오브젝트를 칠하는 커스텀 색상 그리드 (최대 1000칸)
    if (line.startsWith('루루 PIXELART ')) {
      const m = line.slice('루루 PIXELART '.length).match(/^(\S+)\s+(\d+)\s+(\d+)\s*\{$/);
      if (!m) throw new LullangError('SYNTAX', '루루 PIXELART 이름 W H { 형식이 필요합니다.', lineNo, '예: 루루 PIXELART Hero 16 16 {');
      const gw = parseInt(m[2], 10), gh = parseInt(m[3], 10);
      if (gw * gh > 1000) throw new LullangError('SYNTAX', 'PIXELART 그물망은 최대 1000칸까지 입니다 (현재 ' + (gw * gh) + '칸).', lineNo, 'W*H가 1000 이하가 되도록 줄이세요.');
      const rawRows = [];
      while (this.peekLine() !== null && this.peekLine().trim() !== '}') rawRows.push(this.nextLine());
      if (this.peekLine() === null) throw new LullangError('SYNTAX', 'PIXELART 블록이 "}" 로 닫히지 않았습니다.', lineNo, '정의 끝에 }를 추가하세요.');
      this.nextLine();
      return { type: 'pixelart_def', name: m[1], width: gw, height: gh, rawRows, line: lineNo };
    }
    if (line.startsWith('루루 ANIMATION ')) {
      const name = line.slice('루루 ANIMATION '.length).replace(/\{$/, '').trim();
      const rawRows = [];
      while (this.peekLine() !== null && this.peekLine().trim() !== '}') rawRows.push(this.nextLine());
      if (this.peekLine() === null) throw new LullangError('SYNTAX', 'ANIMATION 블록이 "}" 로 닫히지 않았습니다.', lineNo, '애니메이션 정의 끝에 }를 추가하세요.');
      this.nextLine();
      const frames = [];
      rawRows.forEach(raw => {
        const t = raw.trim();
        const m = t.match(/^프레임\s+(\S+)\s+(\d+)$/);
        if (m) frames.push({ sprite: m[1], duration: parseInt(m[2], 10) });
      });
      return { type: 'animation_def', name, frames, line: lineNo };
    }
    // 반복 <횟수> { ... } / REPEAT <횟수> { ... }  -> 즉시(같은 프레임 안에서) N번 반복 실행하는 반복문
    if (line.startsWith('반복 ') || line.startsWith('REPEAT ')) {
      const m = line.match(/^(?:반복|REPEAT)\s+(.+)\s*\{$/);
      if (!m) throw new LullangError('SYNTAX', '반복 <횟수> { (또는 REPEAT <횟수> {) 형식이 필요합니다.', lineNo, '예: 반복 10 { 또는 REPEAT 10 {');
      const countExpr = parseLullangExpression(m[1]);
      const body = this.parseBlock();
      return { type: 'repeat', countExpr, body, line: lineNo };
    }
    throw new LullangError('SYNTAX', '알 수 없는 명령: "' + line + '"', lineNo, '지원되는 명령어(SET/OBJECT/WALL/CLEAR/RENDER/TEXT/룰랄/루루/반복/TOUCH/CAMERA/MAP)를 확인하세요.');
  }
}

/* =========================================================================
   12. INTERPRETER / VM
   ========================================================================= */
function formatLullangValue(v) {
  if (typeof v === 'number') {
    if (Number.isInteger(v)) return String(v);
    return v.toFixed(2);
  }
  return String(v);
}

// OOP: 메서드 실행 중 THIS가 가리키는 오브젝트 id 스택 (중첩 메서드 호출 지원)
const LullangThisStack = [];
function resolveObjectIdForField(target) {
  return target === 'THIS' ? (LullangThisStack[LullangThisStack.length - 1] || null) : target;
}
function getObjectField(target, field) {
  const realId = resolveObjectIdForField(target);
  const o = LullangObjectManager.get(realId);
  if (!o) return 0;
  if (o.classFields && field in o.classFields) return o.classFields[field];
  const key = field.toLowerCase();
  if (key === 'x') return o.x; if (key === 'y') return o.y;
  if (key === 'width') return o.width; if (key === 'height') return o.height;
  if (key === 'size') return o.size; if (key === 'angle') return o.angle;
  if (key === 'scale') return o.scale; if (key === 'layer') return o.layer;
  if (key === 'active') return o.active ? 1 : 0; if (key === 'visible') return o.visible ? 1 : 0;
  return 0;
}
function setObjectField(target, field, value) {
  const realId = resolveObjectIdForField(target);
  const o = LullangObjectManager.get(realId);
  if (!o) { pushProblem('warning', 'RUNTIME', '존재하지 않는 오브젝트의 필드에 대입 시도: ' + target, '?', 'NEW 로 먼저 인스턴스를 생성하세요.'); return false; }
  if (!o.classFields) o.classFields = {};
  o.classFields[field] = value;
  return true;
}

function evaluateLullangExpr(node) {
  switch (node.type) {
    case 'num': return node.value;
    case 'str': return node.value;
    case 'ident': return (node.name in LULLANG_BUILTIN_CONSTS) ? LULLANG_BUILTIN_CONSTS[node.name] : LullangVariables.getVar(node.name);
    case 'listget': return LullangVariables.getListItem(node.name, evaluateLullangExpr(node.index));
    case 'listfunc': {
      const list = LullangVariables.getList(node.listName);
      if (node.name === 'LEN') return list.length;
      if (node.name === 'SUM') return list.reduce((a, b) => a + b, 0);
      if (node.name === 'AVG') return list.length ? list.reduce((a, b) => a + b, 0) / list.length : 0;
      return 0;
    }
    case 'fieldget': return getObjectField(node.target, node.field);
    case 'ram': return RAM[Math.max(0, Math.min(RAM_SIZE - 1, Math.floor(evaluateLullangExpr(node.index))))];
    case 'iscollide': return LullangCollision.isCollidingById(evaluateLullangExpr(node.a), evaluateLullangExpr(node.b)) ? 1 : 0;
    case 'call': {
      const args = node.args.map(evaluateLullangExpr);
      switch (node.name) {
        case 'RANDOM': { const lo = args[0] !== undefined ? args[0] : 0, hi = args[1] !== undefined ? args[1] : 1; return lo + Math.random() * (hi - lo); }
        case 'ABS': return Math.abs(args[0]);
        case 'MIN': return Math.min(...args);
        case 'MAX': return Math.max(...args);
        case 'FLOOR': return Math.floor(args[0]);
        case 'ROUND': return Math.round(args[0]);
        case 'SQRT': return Math.sqrt(args[0]);
        case 'SIN': return Math.sin((args[0] || 0) * Math.PI / 180);
        case 'COS': return Math.cos((args[0] || 0) * Math.PI / 180);
        case 'TAN': return Math.tan((args[0] || 0) * Math.PI / 180);
        case 'ASIN': return Math.asin(args[0]) * 180 / Math.PI;
        case 'ACOS': return Math.acos(args[0]) * 180 / Math.PI;
        case 'ATAN': return Math.atan(args[0]) * 180 / Math.PI;
        case 'POW': return Math.pow(args[0], args[1]);
        case 'CLAMP': return Math.min(Math.max(args[0], args[1]), args[2]);
        case 'ATAN2': return Math.atan2(args[0], args[1]) * 180 / Math.PI;
        case 'LOG': return Math.log(args[0]);
        case 'EXP': return Math.exp(args[0]);
        case 'LERP': return args[0] + (args[1] - args[0]) * args[2];
        case 'DIST': return Math.sqrt(Math.pow(args[2] - args[0], 2) + Math.pow(args[3] - args[1], 2));
        case 'TIMER': return (performance.now() - lullangRunStartTime) / 1000;
      }
      return 0;
    }
    case 'unop': { const v = evaluateLullangExpr(node.expr); if (node.op === '!') return v ? 0 : 1; if (node.op === '-') return -v; break; }
    case 'logic': { const l = evaluateLullangExpr(node.left); if (node.op === '&&') return (l && evaluateLullangExpr(node.right)) ? 1 : 0; if (node.op === '||') return (l || evaluateLullangExpr(node.right)) ? 1 : 0; break; }
    case 'binop': {
      const l = evaluateLullangExpr(node.left), r = evaluateLullangExpr(node.right);
      switch (node.op) {
        case '+': return l + r; case '-': return l - r; case '*': return l * r;
        case '/': return r === 0 ? 0 : l / r; case '%': return r === 0 ? 0 : l % r;
        case '>': return l > r ? 1 : 0; case '<': return l < r ? 1 : 0;
        case '>=': return l >= r ? 1 : 0; case '<=': return l <= r ? 1 : 0;
        case '==': return l === r ? 1 : 0; case '!=': return l !== r ? 1 : 0;
      }
      break;
    }
  }
  return 0;
}

// 변수/리스트 "선언 전 사용" 정적 검사. 함수 본문은 호출 시점을 컴파일 타임에 알 수 없으므로
// "프로그램 어디선가 선언된 적이 있는가"로 검사하고, 최상위(top-level) 코드는 위→아래 실행 순서 그대로 검사한다.
function checkLullangDeclarationOrder(program) {
  const allDeclared = new Set();
  const collectAll = (list) => list.forEach(s => {
    if (s.type === 'var_decl' || s.type === 'list_decl') allDeclared.add(s.name);
    if (s.thenBody) collectAll(s.thenBody);
    if (s.elseBody) collectAll(s.elseBody);
    if (s.body) collectAll(s.body);
  });
  collectAll(program);

  function checkExprNames(node, knownSet, lineNo) {
    if (!node || typeof node !== 'object') return;
    if (node.type === 'ident' || node.type === 'listget') {
      if (node.type === 'ident' && (node.name in LULLANG_BUILTIN_CONSTS)) { /* 내장 상수는 선언 불필요 */ }
      else if (!knownSet.has(node.name)) {
        throw new LullangError('DECLARATION', '선언되지 않은 변수 "' + node.name + '" 를 사용했습니다.', lineNo, '먼저 "변수 ' + node.name + '는 값" 또는 "리스트 ' + node.name + '는 [값, 값, ...]" 으로 선언한 뒤 사용하세요.');
      }
    }
    ['left', 'right', 'expr', 'index', 'a', 'b'].forEach(k => { if (node[k]) checkExprNames(node[k], knownSet, lineNo); });
    if (node.args) node.args.forEach(a => checkExprNames(a, knownSet, lineNo));
  }
  function checkStmtExprs(stmt, knownSet) {
    ['xExpr', 'yExpr', 'wExpr', 'hExpr', 'valueExpr', 'indexExpr', 'condExpr'].forEach(f => { if (stmt[f]) checkExprNames(stmt[f], knownSet, stmt.line); });
    if (stmt.itemExprs) stmt.itemExprs.forEach(e => checkExprNames(e, knownSet, stmt.line));
  }
  function walkFuncBody(list) {
    list.forEach(s => {
      checkStmtExprs(s, allDeclared);
      if (s.thenBody) walkFuncBody(s.thenBody);
      if (s.elseBody) walkFuncBody(s.elseBody);
      if (s.body) walkFuncBody(s.body);
    });
  }
  const declaredSoFar = new Set();
  function walkTopLevel(list) {
    list.forEach(s => {
      if (s.type === 'func_def') { walkFuncBody(s.body); return; }
      checkStmtExprs(s, declaredSoFar);
      if (s.thenBody) walkTopLevel(s.thenBody);
      if (s.elseBody) walkTopLevel(s.elseBody);
      if (s.body) walkTopLevel(s.body);
      if (s.type === 'var_decl' || s.type === 'list_decl') declaredSoFar.add(s.name);
    });
  }
  walkTopLevel(program);
}

class LullangInterpreterClass {
  constructor() { this.functions = new Map(); this.mainBody = []; this.classes = new Map(); this.callDepth = 0; }
  compile(sourceText) {
    this.functions.clear(); this.mainBody = []; this.classes.clear();
    const program = new LullangStatementParser(sourceText).parseProgram();
    checkLullangDeclarationOrder(program);
    program.forEach(stmt => {
      if (stmt.type === 'func_def') { this.functions.set(stmt.name, stmt.body); }
      else if (stmt.type === 'sprite_def') { LullangSpriteManager.register(stmt.name, stmt.rows); this.mainBody.push(stmt); }
      else if (stmt.type === 'shape_def') { LullangShapeManager.register(stmt.name, parseLullangShapeRows(stmt.rawRows)); this.mainBody.push(stmt); }
      else if (stmt.type === 'animation_def') { LullangAnimationManager.register(stmt.name, stmt.frames); this.mainBody.push(stmt); }
      else if (stmt.type === 'pixelart_def') { LullangPixelArtManager.register(stmt.name, stmt.width, stmt.height, parseLullangPixelArtRows(stmt.rawRows)); this.mainBody.push(stmt); }
      else if (stmt.type === 'image_load') { LullangImageManager.load(stmt.name, stmt.url); this.mainBody.push(stmt); }
      else if (stmt.type === 'sound_load') { LullangAudio.load(stmt.name, stmt.url); this.mainBody.push(stmt); }
      else if (stmt.type === 'map') { LullangTileManager.loadMap(stmt.rows); this.mainBody.push(stmt); }
      else if (stmt.type === 'class_def') { this.registerClass(stmt); }
      else this.mainBody.push(stmt);
    });
    this.checkWarnings(program);
    return program;
  }
