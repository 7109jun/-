// 에디터에서 특정 줄(1-indexed)을 통째로 삭제 - Alt키로 오류 줄을 즉시 지우는 데 사용
function deleteEditorLine(lineNum) {
  const lines = editorInput.value.split('\n');
  if (lineNum < 1 || lineNum > lines.length) return false;
  lines.splice(lineNum - 1, 1);
  editorInput.value = lines.join('\n');
  refreshEditorView(); LullangFS.save(editorInput.value);
  return true;
}
window.addEventListener('keydown', (e) => {
  const typing = document.activeElement === editorInput;
  // Alt: 가장 최근 문법 오류가 발생한 줄을 즉시 삭제
  if (e.key === 'Alt') {
    if (lullangLastErrorLine !== null) {
      e.preventDefault();
      const deletedLine = lullangLastErrorLine;
      if (deleteEditorLine(lullangLastErrorLine)) {
        consoleLog('info', 'Alt: ' + deletedLine + '번째 줄(오류 발생 줄) 삭제됨');
        lullangLastErrorLine = null;
      }
    }
    return;
  }
  // Tab: 언어 매뉴얼 토글 (에디터에 포커스가 있을 때는 기존 Tab/스니펫 기능을 그대로 사용)
  if (e.key === 'Tab' && !typing) { e.preventDefault(); toggleManual(); return; }
  // Ctrl+N: 새 파일
  if (e.ctrlKey && !e.shiftKey && (e.key === 'n' || e.key === 'N')) { e.preventDefault(); createNewLullangFile(); return; }
  // Ctrl+S: 명시적 저장(자동저장은 이미 되지만, 확인 피드백을 준다)
  if (e.ctrlKey && (e.key === 's' || e.key === 'S')) {
    e.preventDefault(); LullangFS.save(editorInput.value); flashSaveToast(); consoleLog('info', LullangFS.activeFile + ' 저장됨'); return;
  }
  // Ctrl+R: RESTART
  if (e.ctrlKey && !e.shiftKey && (e.key === 'r' || e.key === 'R')) { e.preventDefault(); document.getElementById('restartBtn2').click(); return; }
  // F5: RUN, Shift+F5: STOP
  if (e.key === 'F5') { e.preventDefault(); if (e.shiftKey) document.getElementById('stopBtn2').click(); else document.getElementById('runBtn2').click(); return; }
  // Delete: 에디터에 포커스가 없을 때, 선택된 Explorer 파일 삭제
  if (e.key === 'Delete' && !typing && explorerSelectedFile) { e.preventDefault(); deleteLullangFile(explorerSelectedFile); return; }
});

/* =========================================================================
   17.6 PROJECT SAVE / LOAD (마크다운 내보내기·불러오기, 자체 HTML 저장)
   ========================================================================= */
const LULLANG_SAVE_MARKER_ID = 'lullangEmbeddedSaveData';

// 저장 포맷: Name(파일명)age(나이)Layer(레이어)code(코드) 를 파일 개수만큼 반복하고
// 항목 사이는 "," 로 구분한다("Name(" 바로 앞의 콤마만 구분자로 취급해서 코드 안의 일반 콤마와 헷갈리지 않음).
// "/: 주석내용" 처럼 줄 앞에 /:를 붙이면 사람이 읽는 주석이 되어 불러올 때 무시된다.
function exportProjectAsMarkdown() {
  let md = '/: Lullang IDE 프로젝트 내보내기 — Name(파일명)age(나이)Layer(레이어)code(코드), 항목 구분자: ,\n\n';
  const parts = LullangFS.order.map(name => {
    return 'Name(' + name + ')age(' + LullangFS.getAge(name) + ')Layer(' + LullangFS.getLayer(name) + ')code(' + LullangFS.files[name] + ')';
  });
  md += parts.join(',\n');
  const blob = new Blob([md], { type: 'text/plain' });
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a');
  a.href = url; a.download = 'lullang-project.lni';
  document.body.appendChild(a); a.click(); document.body.removeChild(a);
  URL.revokeObjectURL(url);
  consoleLog('info', '.lni로 내보내기 완료: lullang-project.lni');
}

function importProjectFromMarkdownText(text) {
  // /: 로 시작하는 줄은 주석이므로 통째로 제거
  const cleaned = text.split('\n').filter(l => !l.trim().startsWith('/:')).join('\n');
  // "Name(" 바로 앞의 콤마만 진짜 구분자로 취급 (코드 안의 일반 콤마는 그대로 둠)
  const chunks = cleaned.split(/,(?=\s*Name\()/).map(s => s.trim()).filter(Boolean);
  const newFiles = {}, newOrder = [], newMeta = {};
  chunks.forEach(chunk => {
    const nameMatch = chunk.match(/Name\((.*?)\)/);
    const ageMatch = chunk.match(/age\((.*?)\)/);
    const layerMatch = chunk.match(/Layer\((.*?)\)/);
    const codeStart = chunk.indexOf('code(');
    if (!nameMatch || codeStart === -1) return;
    const lastParen = chunk.lastIndexOf(')');
    if (lastParen <= codeStart) return;
    const code = chunk.slice(codeStart + 5, lastParen);
    const name = nameMatch[1].trim();
    newFiles[name] = code;
    newOrder.push(name);
    newMeta[name] = { age: ageMatch ? parseInt(ageMatch[1], 10) : 0, layer: layerMatch ? parseInt(layerMatch[1], 10) : 0 };
  });
  if (newOrder.length === 0) { alert('.lni 파일에서 파일을 찾지 못했습니다. 형식을 확인하세요 (Name()age()Layer()code(), 구분자 콤마).'); return; }
  if (!confirm(newOrder.length + '개 파일을 불러옵니다. 현재 프로젝트 내용을 덮어씁니다. 계속할까요?')) return;
  LullangFS.files = newFiles; LullangFS.order = newOrder; LullangFS.meta = newMeta; LullangFS.activeFile = newOrder[0];
  loadFileIntoEditor(LullangFS.activeFile);
  toggleManual();
  consoleLog('info', '마크다운에서 프로젝트 불러오기 완료 (' + newOrder.length + '개 파일, 기존 내용 덮어씀)');
}

function triggerMarkdownImport() {
  const input = document.createElement('input');
  input.type = 'file'; input.accept = '.lni,.md,text/markdown,text/plain';
  input.addEventListener('change', () => {
    const file = input.files[0]; if (!file) return;
    const reader = new FileReader();
    reader.onload = () => importProjectFromMarkdownText(reader.result);
    reader.readAsText(file);
  });
  input.click();
}

// 브라우저 저장소(localStorage 등)를 쓰지 않고, 현재 상태를 담은 새 HTML 파일 자체를 다운로드하는 방식으로 저장한다.
// 이 파일을 다시 열면 부팅 시 아래쪽 loadEmbeddedSaveIfPresent()가 내장된 데이터를 읽어서 그대로 이어서 쓸 수 있다.
function saveProjectIntoOwnHtml() {
  const dataJson = JSON.stringify({ files: LullangFS.files, order: LullangFS.order, meta: LullangFS.meta, activeFile: LullangFS.activeFile });
  let htmlSrc = '<!DOCTYPE html>\n' + document.documentElement.outerHTML;
  const CLOSE_SCRIPT_TAG = '</' + 'script>';
  const markerRegex = new RegExp('<script type="text/plain" id="' + LULLANG_SAVE_MARKER_ID + '">[\\s\\S]*?' + CLOSE_SCRIPT_TAG);
  const safeJson = dataJson.replace(/</g, '\\u003c');
  const newTag = '<script type="text/plain" id="' + LULLANG_SAVE_MARKER_ID + '">' + safeJson + CLOSE_SCRIPT_TAG;
  const OPEN_SCRIPT_TAG = '<' + 'script>';
  if (markerRegex.test(htmlSrc)) htmlSrc = htmlSrc.replace(markerRegex, newTag);
  else htmlSrc = htmlSrc.replace(OPEN_SCRIPT_TAG, newTag + '\n' + OPEN_SCRIPT_TAG);
  const blob = new Blob([htmlSrc], { type: 'text/html' });
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a');
  a.href = url; a.download = 'lullang-ide-save.html';
  document.body.appendChild(a); a.click(); document.body.removeChild(a);
  URL.revokeObjectURL(url);
  consoleLog('info', '현재 상태를 담은 HTML로 저장 완료: lullang-ide-save.html (이 파일을 다시 열면 저장 시점 그대로 이어집니다)');
}

function loadEmbeddedSaveIfPresent() {
  const tag = document.getElementById(LULLANG_SAVE_MARKER_ID);
  if (!tag) return false;
  try {
    const data = JSON.parse(tag.textContent);
    if (data && data.files && data.order && data.order.length) {
      LullangFS.files = data.files; LullangFS.order = data.order; LullangFS.meta = data.meta || {};
      LullangFS.activeFile = data.activeFile || data.order[0];
      return true;
    }
  } catch (e) { console.error('임베디드 저장 데이터 파싱 실패', e); }
  return false;
}

// PNG/JPG 이미지를 골라서 data URI로 변환한 뒤, IMAGE 문을 에디터 커서 위치에 자동 삽입
const uploadedImages = []; // [{name, dataUri}]
const uploadedSounds = []; // [{name, dataUri, sizeMB}]
const LULLANG_MAX_SOUNDS = 675; // 오디오는 데이터가 커서 웹이 느려질 수 있어 개수를 제한함
function extFromFile(file, fallback) {
  const m = file.name.match(/\.([A-Za-z0-9]+)$/);
  return m ? m[1].toLowerCase() : fallback;
}
function triggerImageUpload() {
  const input = document.createElement('input');
  input.type = 'file'; input.accept = 'image/png,image/jpeg';
  input.addEventListener('change', () => {
    const file = input.files[0]; if (!file) return;
    const ext = extFromFile(file, 'png') === 'jpeg' ? 'jpg' : extFromFile(file, 'png');
    const name = '사진' + (uploadedImages.length + 1) + '.' + ext;
    const reader = new FileReader();
    reader.onload = () => {
      const dataUri = reader.result;
      LullangImageManager.load(name, dataUri);
      uploadedImages.push({ name, dataUri });
      renderAssetGallery();
      consoleLog('info', '이미지 업로드 완료: ' + name + ' (SET id IMAGE ' + name + ' 로 바로 사용 가능)');
    };
    reader.readAsDataURL(file);
  });
  input.click();
}
function triggerSoundUpload() {
  if (uploadedSounds.length >= LULLANG_MAX_SOUNDS) { alert('사운드는 최대 ' + LULLANG_MAX_SOUNDS + '개까지만 업로드할 수 있습니다.'); return; }
  const input = document.createElement('input');
  input.type = 'file'; input.accept = 'audio/*';
  input.addEventListener('change', () => {
    const file = input.files[0]; if (!file) return;
    const sizeMB = file.size / (1024 * 1024);
    if (sizeMB > 1024) { alert('사운드 파일은 1GB 이하만 업로드할 수 있습니다.'); return; }
    const ext = extFromFile(file, 'mp3');
    const name = '노래' + (uploadedSounds.length + 1) + '.' + ext;
    const reader = new FileReader();
    reader.onload = () => {
      const dataUri = reader.result;
      LullangAudio.load(name, dataUri);
      uploadedSounds.push({ name, dataUri, sizeMB: sizeMB.toFixed(1) });
      renderAssetGallery();
      consoleLog('info', '사운드 업로드 완료: ' + name + ' (릴리랄 ' + name + ' 재생 으로 바로 사용 가능)');
    };
    reader.readAsDataURL(file);
  });
  input.click();
}
function renderAssetGallery() {
  const el = document.getElementById('assetGalleryBody');
  if (!el) return;
  if (!uploadedImages.length && !uploadedSounds.length) { el.innerHTML = '<span class="manual-note">아직 업로드한 사진/사운드가 없습니다.</span>'; return; }
  let html = '';
  if (uploadedImages.length) {
    html += '<div style="display:flex;flex-wrap:wrap;gap:8px;margin-bottom:10px;">' + uploadedImages.map(im =>
      '<div style="text-align:center;font-size:10.5px;color:var(--text-faint);"><img src="' + im.dataUri + '" style="width:48px;height:48px;object-fit:cover;border-radius:6px;border:1px solid var(--border);display:block;margin-bottom:3px;">' + im.name + '</div>'
    ).join('') + '</div>';
  }
  if (uploadedSounds.length) {
    html += '<div style="display:flex;flex-direction:column;gap:4px;">' + uploadedSounds.map(s =>
      '<div style="font-family:var(--font-mono);font-size:11px;color:var(--text-dim);">' + s.name + ' (' + s.sizeMB + 'MB)</div>'
    ).join('') + '</div>';
  }
  el.innerHTML = html;
}

