<script>
(() => {
'use strict';

/* =========================================================================
   0. ERROR SYSTEM
   ========================================================================= */
class LullangError extends Error {
  constructor(type, message, line, suggestion) {
    super(message);
    this.errType = type; this.line = line !== undefined ? line : '?'; this.suggestion = suggestion || '문법과 들여쓰기를 확인하세요.';
  }
}
const problems = [];
let lullangLastErrorLine = null; // Alt키로 즉시 삭제할 대상 줄 (가장 최근 에러 라인)
function pushProblem(severity, type, message, line, suggestion) {
  problems.push({ severity, type, message, line: line !== undefined ? line : '?', suggestion: suggestion || '문법과 들여쓰기를 확인하세요.' });
  if (severity === 'error' && typeof line === 'number' && isFinite(line)) lullangLastErrorLine = line;
  renderProblems();
}
function clearProblems() { problems.length = 0; lullangLastErrorLine = null; renderProblems(); }

const consoleLines = [];
function consoleLog(kind, text) {
  consoleLines.push({ kind, text, t: new Date().toLocaleTimeString() });
  if (consoleLines.length > 300) consoleLines.shift();
  renderConsole();
}

/* =========================================================================
   1. RAM
   ========================================================================= */
const RAM_SIZE = 256;
const RAM = new Array(RAM_SIZE).fill(0);
const LULLANG_MAX_OBJECTS = 2000; // 파일(프로젝트)당 코드로 생성 가능한 오브젝트 최대 개수 (수백~수천 오브젝트 지원)

/* =========================================================================
   2. TOKENIZER (expressions)
   ========================================================================= */
class LullangTokenizer {
  constructor(src) { this.src = src; }
  isDigit(c) { return c >= '0' && c <= '9'; }
  isIdentStart(c) { return /[A-Za-z_가-힣]/.test(c); }
  isIdentPart(c) { return /[A-Za-z0-9_가-힣]/.test(c); }
  tokenize() {
    const s = this.src;
    let i = 0;
    const tokens = [];
    while (i < s.length) {
      const c = s[i];
      if (c === ' ' || c === '\t') { i++; continue; }
      if (this.isDigit(c) || (c === '.' && this.isDigit(s[i + 1]))) {
        let j = i; while (j < s.length && (this.isDigit(s[j]) || s[j] === '.')) j++;
        tokens.push({ type: 'NUMBER', value: parseFloat(s.slice(i, j)) });
        i = j; continue;
      }
      if (this.isIdentStart(c)) {
        let j = i; while (j < s.length && this.isIdentPart(s[j])) j++;
        tokens.push({ type: 'IDENT', value: s.slice(i, j) });
        i = j; continue;
      }
      if (c === '#') {
        let j = i + 1; while (j < s.length && /[0-9a-fA-F]/.test(s[j])) j++;
        tokens.push({ type: 'STRING', value: s.slice(i, j) });
        i = j; continue;
      }
      if (c === '"') {
        let j = i + 1; while (j < s.length && s[j] !== '"') j++;
        tokens.push({ type: 'STRING', value: s.slice(i + 1, j) });
        i = j + 1; continue;
      }
      const two = s.slice(i, i + 2);
      if (['==', '!=', '>=', '<=', '&&', '||'].includes(two)) { tokens.push({ type: 'OP', value: two }); i += 2; continue; }
      if ('+-*/%()[]!<>,{}=.'.includes(c)) { tokens.push({ type: 'OP', value: c }); i++; continue; }
      i++;
    }
    tokens.push({ type: 'EOF', value: null });
    return tokens;
  }
}

const LULLANG_BUILTIN_FUNCS = new Set(['RANDOM', 'ABS', 'MIN', 'MAX', 'FLOOR', 'ROUND', 'SQRT', 'SIN', 'COS', 'TAN', 'ASIN', 'ACOS', 'ATAN', 'POW', 'CLAMP', 'ATAN2', 'LOG', 'EXP', 'LERP', 'DIST', 'TIMER']);
const LULLANG_LIST_FUNCS = new Set(['LEN', 'SUM', 'AVG']); // 리스트 이름을 통째로 받는 데이터분석용 함수
const LULLANG_BUILTIN_CONSTS = { 'PI': Math.PI, 'E': Math.E };

/* =========================================================================
   3. EXPRESSION PARSER -> AST  (recursive descent, no eval/new Function)
   ========================================================================= */
class LullangExprParser {
  constructor(tokens) { this.tokens = tokens; this.pos = 0; }
  peek() { return this.tokens[this.pos]; }
  next() { return this.tokens[this.pos++]; }
  expect(value) {
    const t = this.next();
    if (t.value !== value) throw new LullangError('SYNTAX', '"' + value + '" 를 예상했지만 "' + t.value + '" 를 발견함', 0, '식 문법을 확인하세요: ' + value + ' 위치');
    return t;
  }
  parseExpression() { return this.parseLogicOr(); }
  parseLogicOr() { let n = this.parseLogicAnd(); while (this.peek().value === '||') { this.next(); n = { type: 'logic', op: '||', left: n, right: this.parseLogicAnd() }; } return n; }
  parseLogicAnd() { let n = this.parseEquality(); while (this.peek().value === '&&') { this.next(); n = { type: 'logic', op: '&&', left: n, right: this.parseEquality() }; } return n; }
  parseEquality() { let n = this.parseComparison(); while (['==', '!='].includes(this.peek().value)) { const op = this.next().value; n = { type: 'binop', op, left: n, right: this.parseComparison() }; } return n; }
  parseComparison() { let n = this.parseAdditive(); while (['>', '<', '>=', '<='].includes(this.peek().value)) { const op = this.next().value; n = { type: 'binop', op, left: n, right: this.parseAdditive() }; } return n; }
  parseAdditive() { let n = this.parseMultiplicative(); while (['+', '-'].includes(this.peek().value)) { const op = this.next().value; n = { type: 'binop', op, left: n, right: this.parseMultiplicative() }; } return n; }
