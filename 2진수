한글을 2진수로 <!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>한글 2진수 변환기</title>
    <style>
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: #0f172a;
            color: #e2e8f0;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            margin: 0;
        }
        .container {
            background-color: #1e293b;
            padding: 2.5rem;
            border-radius: 16px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.3);
            width: 100%;
            max-width: 550px;
        }
        h1 {
            font-size: 1.8rem;
            margin-bottom: 1.5rem;
            color: #38bdf8;
            text-align: center;
        }
        textarea {
            width: 100%;
            height: 100px;
            background-color: #0f172a;
            border: 2px solid #334155;
            border-radius: 8px;
            color: #fff;
            padding: 10px;
            box-sizing: border-box;
            resize: none;
            font-size: 1rem;
            margin-bottom: 1rem;
        }
        textarea:focus {
            outline: none;
            border-color: #38bdf8;
        }
        button {
            width: 100%;
            background-color: #38bdf8;
            color: #0f172a;
            border: none;
            padding: 12px;
            border-radius: 8px;
            font-size: 1rem;
            font-weight: bold;
            cursor: pointer;
            transition: background 0.2s;
        }
        button:hover {
            background-color: #0ea5e9;
        }
        .result-box {
            margin-top: 1.5rem;
        }
        .label-group {
            display: flex;
            justify-content: space-between;
            margin-bottom: 0.5rem;
        }
        label {
            font-size: 0.9rem;
            color: #94a3b8;
        }
        .notice {
            font-size: 0.8rem;
            color: #f43f5e;
        }
        #output {
            background-color: #0f172a;
            padding: 12px;
            border-radius: 8px;
            min-height: 80px;
            max-height: 200px;
            overflow-y: auto;
            word-break: break-all;
            font-family: 'Courier New', Courier, monospace;
            color: #4ade80;
            border: 1px solid #334155;
            letter-spacing: 1px;
            line-height: 1.6;
        }
    </style>
</head>
<body>

    <div class="container">
        <h1>한글 ⇄ 2진수 변환기 (Ultra)</h1>
        <textarea id="input" placeholder="문장을 입력하세요... (영문, 숫자, 한글 혼용 가능)"></textarea>
        <button onclick="convertToEucKrBinary()">고성능 변환하기</button>
        
        <div class="result-box">
            <div class="label-group">
                <label>변환 결과 (8비트 바이트 단위 분리):</label>
                <span class="notice">* EUC-KR 미지원 문자는 00111111(?)로 변환됨</span>
            </div>
            <div id="output">이곳에 올바른 2진수가 표시됩니다.</div>
        </div>
    </div>

    <script>
        // 질문자님이 최적화해주신 마스터피스 로직
        async function convertToEucKrBinary() {
            const input = document.getElementById('input').value;
            const output = document.getElementById('output');
            
            if (!input) {
                output.innerText = "텍스트를 입력해 주세요.";
                return;
            }

            try {
                // 1. 전체 텍스트를 한 번에 Blob 처리하여 성능 극대화 (O(1) 비동기화)
                const blob = new Blob([input], { type: 'text/plain;charset=euc-kr' });
                const buffer = await new Response(blob).arrayBuffer();
                const bytes = new Uint8Array(buffer);
                
                // 2. 가독성을 위해 각 바이트를 무조건 8비트 단위로 깔끔하게 쪼개기
                let result = [];
                bytes.forEach(byte => {
                    result.push(byte.toString(2).padStart(8, '0'));
                });
                
                // 3. 완벽한 화면 출력
                output.innerText = result.join(' ');
                
            } catch (e) {
                output.innerText = "인코딩 오류가 발생했습니다.";
                console.error(e);
            }
        }
    </script>

</body>
</html>
