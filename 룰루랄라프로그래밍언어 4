function renderObjectList(force) {
  objectListThrottleCounter++;
  if (!force && objectListThrottleCounter < OBJECT_LIST_THROTTLE_FRAMES) return;
  objectListThrottleCounter = 0;
  const objs = LullangObjectManager.all();
  document.getElementById('objCountBadge').textContent = objs.length;
  if (!objs.length) { objectListBody.innerHTML = '<div class="obj-empty">오브젝트가 없습니다.</div>'; return; }
  objectListBody.innerHTML = objs.map(o =>
    '<div class="obj-row"><span class="obj-id">' + o.id + '</span><span class="obj-type">' + o.type + '</span><span>(' + Math.round(o.x) + ',' + Math.round(o.y) + ')</span></div>'
  ).join('');
}

const lullangCanvasEl = document.getElementById('lullangCanvas');
const LullangRenderer = new LullangRendererClass(lullangCanvasEl);
LullangInput.bindCanvas(lullangCanvasEl);

let lullangRunning = false;
let lullangFrameCount = 0, lullangFpsLastSample = performance.now(), lullangFps = 0;
const fpsBadgeEl = document.getElementById('fpsBadge');
const runStatusEl = document.getElementById('topRunStatus');

function lullangGameLoop(now) {
  if (!lullangRunning) return;
  lullangFrameCount++;
  if (now - lullangFpsLastSample >= 500) {
    lullangFps = Math.round(lullangFrameCount / ((now - lullangFpsLastSample) / 1000));
    lullangFrameCount = 0; lullangFpsLastSample = now;
    fpsBadgeEl.textContent = lullangFps + ' FPS';
  }
  LullangInput.syncToRam();
  LullangCamera.update(lullangCanvasEl.width, lullangCanvasEl.height);
  try {
    LullangInterpreter.runFrame();
  } catch (err) {
    lullangRunning = false;
    runStatusEl.textContent = 'error';
    const e = err instanceof LullangError ? err : new LullangError('RUNTIME', err.message, '?', '런타임 오류입니다. Problems 탭을 확인하세요.');
    pushProblem('error', e.errType, e.message, e.line, e.suggestion);
    consoleLog('err', '실행 중단: ' + e.message);
    return;
  }
  renderObjectList(); // 스로틀 적용됨: 매 프레임 호출해도 실제 DOM 갱신은 6프레임마다 1회
  requestAnimationFrame(lullangGameLoop);
}

function compileActiveFile() {
  clearProblems();
  const source = editorInput.value;
  try {
    const program = LullangInterpreter.compile(source);
    renderAstView(program);
    renderTokensView(source);
    consoleLog('info', LullangFS.activeFile + ' 컴파일 성공 (' + program.length + '개 최상위 구문)');
    return true;
  } catch (err) {
    const e = err instanceof LullangError ? err : new LullangError('COMPILE', err.message, '?', '문법을 다시 확인하세요.');
    pushProblem('error', e.errType, e.message, e.line, e.suggestion);
    consoleLog('err', '컴파일 실패: ' + e.message);
    return false;
  }
}

document.getElementById('runBtn2').addEventListener('click', () => {
  if (lullangRunning) return;
  if (!compileActiveFile()) { runStatusEl.textContent = 'compile error'; return; }
  lullangRunning = true;
  runStatusEl.textContent = 'running';
  consoleLog('info', 'RUN — ' + LullangFS.activeFile);
  requestAnimationFrame(lullangGameLoop);
});
document.getElementById('stopBtn2').addEventListener('click', () => {
  lullangRunning = false;
  runStatusEl.textContent = 'stopped';
  consoleLog('info', 'STOP');
});
document.getElementById('restartBtn2').addEventListener('click', () => {
  lullangRunning = false;
  LullangObjectManager.clearAll();
  for (let i = 0; i < RAM_SIZE; i++) RAM[i] = 0;
  LullangVariables.reset();
  LullangCamera.x = 0; LullangCamera.y = 0; LullangCamera.zoom = 1; LullangCamera.followId = null;
  LullangTileManager.rows = [];
  clearProblems();
  consoleLog('info', 'RESTART — 상태 초기화 완료 (변수/리스트 포함)');
  renderObjectList(true);
  if (!compileActiveFile()) { runStatusEl.textContent = 'compile error'; return; }
  lullangRunning = true;
  runStatusEl.textContent = 'running';
  requestAnimationFrame(lullangGameLoop);
});

/* =========================================================================
   17.5 GLOBAL KEYBOARD SHORTCUTS
   ========================================================================= */
const saveToastEl = document.createElement('div');
saveToastEl.id = 'lullangSaveToast';
saveToastEl.textContent = '저장됨';
document.body.appendChild(saveToastEl);
let saveToastTimer = null;
function flashSaveToast() {
  saveToastEl.classList.add('show');
  clearTimeout(saveToastTimer);
  saveToastTimer = setTimeout(() => saveToastEl.classList.remove('show'), 1000);
}
window.addEventListener('keydown', (e) => {
  const typing = document.activeElement === editorInput;
  // Tab: 언어 매뉴얼 토글 (에디터에 포커스가 있을 때는 기존 Tab/스니펫 기능을 그대로 사용)
  if (e.key === 'Tab' && !typing) { e.preventDefault(); toggleManual(); return; }
  // Ctrl+N: 새 파일
  if (e.ctrlKey && !e.shiftKey && (e.key === 'n' || e.key === 'N')) { e.preventDefault(); createNewLullangFile(); return; }
  // Ctrl+S: 명시적 저장(자동저장은 이미 되지만, 확인 피드백을 준다)
  if (e.ctrlKey && (e.key === 's' || e.key === 'S')) {
    e.preventDefault(); LullangFS.save(editorInput.value); flashSaveToast(); consoleLog('info', LullangFS.activeFile + ' 저장됨'); return;
  }
  // Ctrl+R: RESTART
  if (e.ctrlKey && !e.shiftKey && (e.key === 'r' || e.key === 'R')) { e.preventDefault(); document.getElementById('restartBtn2').click(); return; }
  // F5: RUN, Shift+F5: STOP
  if (e.key === 'F5') { e.preventDefault(); if (e.shiftKey) document.getElementById('stopBtn2').click(); else document.getElementById('runBtn2').click(); return; }
  // Delete: 에디터에 포커스가 없을 때, 선택된 Explorer 파일 삭제
  if (e.key === 'Delete' && !typing && explorerSelectedFile) { e.preventDefault(); deleteLullangFile(explorerSelectedFile); return; }
});

