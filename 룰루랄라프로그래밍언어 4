/* =========================================================================
   5.5 SHAPE MANAGER (점/선/면으로 만드는 커스텀 벡터 도형)
   ========================================================================= */
// 도형은 -50..50 정규화 좌표계에 점을 찍고, 선/면으로 연결해서 만든다.
// 렌더링 시 오브젝트의 width/height 비율로 스케일되어 그려진다.
function parseLullangShapeRows(rawRows) {
  const points = [], lines = [], faces = [];
  rawRows.forEach(raw => {
    const t = raw.trim();
    if (!t || t.startsWith('//')) return;
    const parts = t.split(/\s+/);
    if (parts[0] === '점') {
      points.push([parseFloat(parts[1]) || 0, parseFloat(parts[2]) || 0]);
    } else if (parts[0] === '선') {
      lines.push({ a: parseInt(parts[1], 10), b: parseInt(parts[2], 10), color: parts[3] || null });
    } else if (parts[0] === '면') {
      const indices = []; let color = null;
      for (let i = 1; i < parts.length; i++) {
        if (parts[i].startsWith('#')) color = parts[i];
        else indices.push(parseInt(parts[i], 10));
      }
      faces.push({ indices, color });
    }
  });
  return { points, lines, faces };
}
