const LULLANG_PALETTE = { '.': null, '0': '#000000', '1': '#ffffff', '2': '#f2585a', '3': '#5fd097', '4': '#4da3ff', '5': '#e8b84b', '6': '#c586c0', '7': '#f2884b' };
