const editorInput = document.getElementById('codeEditorInput');
const editorHighlight = document.getElementById('codeHighlight');
const lineGutter = document.getElementById('lineGutter');

function escapeHtml(s) { return s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;'); }
function highlightLullang(src) {
  let html = escapeHtml(src);
  html = html.replace(/(\/\/.*)$/gm, '<span class="tok-comment">$1</span>');
  html = html.replace(/"([^"]*)"/g, '<span class="tok-string">"$1"</span>');
  html = html.replace(/#[0-9a-fA-F]{3,6}\b/g, m => '<span class="tok-color">' + m + '</span>');
  html = html.replace(/\b(\d+(\.\d+)?)\b/g, '<span class="tok-number">$1</span>');
  html = html.replace(/(룰랄|아니면|루루|FUNCTION|END|CALL|SPRITE|OBJECT|WALL|SET|RAM|CLEAR|RENDER|TEXT|MAP|ENDMAP|TOUCH|CAMERA|ISCOLLIDE|COLLIDE|FOLLOW|ZOOM|변수|리스트|클래스|필드|NEW|확장|THIS|MODE|ANGLE)/g, '<span class="tok-keyword">$1</span>');
  html = html.replace(/\b(RANDOM|ABS|MIN|MAX|FLOOR|ROUND|SQRT|SIN|COS|POW|CLAMP)\b/g, '<span class="tok-type">$1</span>');
  html = html.replace(/\b(PLAYER|NPC|ENEMY|PROJECTILE|ITEM|CUSTOM)\b/g, '<span class="tok-type">$1</span>');
  return html;
}
function updateLineGutter(text) {
  const n = text.split('\n').length;
  let out = '';
  for (let i = 1; i <= n; i++) out += i + '\n';
  lineGutter.textContent = out;
}
function refreshEditorView() {
  const val = editorInput.value;
  editorHighlight.innerHTML = highlightLullang(val) + '\n';
  updateLineGutter(val);
}
editorInput.addEventListener('input', () => { refreshEditorView(); LullangFS.save(editorInput.value); });
editorInput.addEventListener('scroll', () => {
  editorHighlight.scrollTop = editorInput.scrollTop; editorHighlight.scrollLeft = editorInput.scrollLeft;
  lineGutter.scrollTop = editorInput.scrollTop;
});
// 코드 바로 생성 기능(스니펫): 트리거 단어를 입력하고 Tab을 누르면 전체 템플릿으로 확장됨.
// 예: "if" + Tab -> 룰랄/아니면 템플릿, "func" + Tab -> 루루 FUNCTION 템플릿
const LULLANG_SNIPPETS = {
  'if': '룰랄 조건 {\n  @CURSOR@\n} 아니면 {\n  \n}',
  'func': '루루 FUNCTION 이름 {\n  @CURSOR@\n}\n루루 END',
  'call': '루루 CALL @CURSOR@',
  'touch': 'TOUCH TYPE_A TYPE_B {\n  @CURSOR@\n}',
  'sprite': '루루 SPRITE 이름 {\n  @CURSOR@\n}',
  'map': 'MAP\n@CURSOR@\nENDMAP',
  'cam': 'CAMERA FOLLOW @CURSOR@',
  'obj': 'OBJECT id TYPE x y w h color',
  'wall': 'WALL x y w h',
  'text': 'TEXT x y "@CURSOR@"',
  'var': '변수 이름는 @CURSOR@0',
  'list': '리스트 이름는 [@CURSOR@]',
  'set': 'SET @CURSOR@'
};
function tryExpandSnippet() {
  const start = editorInput.selectionStart, end = editorInput.selectionEnd;
  if (start !== end) return false;
  const value = editorInput.value;
  const before = value.slice(0, start);
  const m = before.match(/([A-Za-z가-힣_]+)$/);
  if (!m) return false;
  const word = m[1];
  const snippet = LULLANG_SNIPPETS[word];
  if (!snippet) return false;
  const wordStart = start - word.length;
  const cursorMarkerIdx = snippet.indexOf('@CURSOR@');
  const expanded = snippet.replace('@CURSOR@', '');
  editorInput.value = value.slice(0, wordStart) + expanded + value.slice(start);
  const newCursor = wordStart + (cursorMarkerIdx === -1 ? expanded.length : cursorMarkerIdx);
  editorInput.selectionStart = editorInput.selectionEnd = newCursor;
  refreshEditorView(); LullangFS.save(editorInput.value);
  return true;
}
function toggleLineComment() {
  const start = editorInput.selectionStart, end = editorInput.selectionEnd;
  const value = editorInput.value;
  const blockStart = value.lastIndexOf('\n', start - 1) + 1;
  let blockEnd = value.indexOf('\n', end - 1);
  if (blockEnd === -1) blockEnd = value.length;
  const block = value.slice(blockStart, blockEnd);
  const lines = block.split('\n');
  const allCommented = lines.every(l => l.trim() === '' || l.trim().startsWith('//'));
  const newLines = lines.map(l => {
    if (allCommented) return l.replace(/^(\s*)\/\/\s?/, '$1');
    return l.trim() === '' ? l : l.replace(/^(\s*)/, '$1// ');
  });
  const newBlock = newLines.join('\n');
  editorInput.value = value.slice(0, blockStart) + newBlock + value.slice(blockEnd);
  editorInput.selectionStart = blockStart; editorInput.selectionEnd = blockStart + newBlock.length;
  refreshEditorView(); LullangFS.save(editorInput.value);
}
function duplicateCurrentLine() {
  const start = editorInput.selectionStart;
  const value = editorInput.value;
  const lineStart = value.lastIndexOf('\n', start - 1) + 1;
  let lineEnd = value.indexOf('\n', start);
  if (lineEnd === -1) lineEnd = value.length;
  const line = value.slice(lineStart, lineEnd);
  editorInput.value = value.slice(0, lineEnd) + '\n' + line + value.slice(lineEnd);
  editorInput.selectionStart = editorInput.selectionEnd = lineEnd + 1 + (start - lineStart);
  refreshEditorView(); LullangFS.save(editorInput.value);
}
editorInput.addEventListener('keydown', (e) => {
  if (e.ctrlKey && (e.key === 'd' || e.key === 'D')) { e.preventDefault(); duplicateCurrentLine(); return; }
  if (e.ctrlKey && e.key === '/') { e.preventDefault(); toggleLineComment(); return; }
  if (e.key === 'Tab') {
    e.preventDefault();
    if (tryExpandSnippet()) return;
    const start = editorInput.selectionStart, end = editorInput.selectionEnd;
    editorInput.value = editorInput.value.slice(0, start) + '  ' + editorInput.value.slice(end);
    editorInput.selectionStart = editorInput.selectionEnd = start + 2;
    refreshEditorView(); LullangFS.save(editorInput.value);
  } else if (e.key === 'Enter') {
    e.preventDefault();
    const start = editorInput.selectionStart;
    const value = editorInput.value;
    const lineStart = value.lastIndexOf('\n', start - 1) + 1;
    const currentLine = value.slice(lineStart, start);
    const indentMatch = currentLine.match(/^\s*/);
    let indent = indentMatch ? indentMatch[0] : '';
    if (currentLine.trim().endsWith('{')) indent += '  ';
    const insertion = '\n' + indent;
    editorInput.value = value.slice(0, start) + insertion + value.slice(start);
    editorInput.selectionStart = editorInput.selectionEnd = start + insertion.length;
    refreshEditorView(); LullangFS.save(editorInput.value);
  }
});

function loadFileIntoEditor(name) {
  LullangFS.setActive(name);
  editorInput.value = LullangFS.getActive();
  refreshEditorView();
  document.getElementById('editorFileBadge').textContent = name;
