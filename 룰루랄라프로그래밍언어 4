/* =========================================================================
   6. TILE MANAGER
   ========================================================================= */
class LullangTileManagerClass {
  constructor() { this.rows = []; this.tileSize = 20; }
  loadMap(rows) {
    LullangObjectManager.all().filter(o => o._fromTile).forEach(o => LullangObjectManager.objects.delete(o.id));
    this.rows = rows;
    for (let ry = 0; ry < rows.length; ry++) {
      const row = rows[ry];
      for (let rx = 0; rx < row.length; rx++) {
        const ch = row[rx];
        const px = rx * this.tileSize, py = ry * this.tileSize;
        if (ch === '#') {
          const o = LullangObjectManager.createOrUpdate('tile_wall_' + rx + '_' + ry, 'WALL', px, py, this.tileSize, this.tileSize, '#3c3c3c');
          o._fromTile = true;
        } else if (ch === 'P') {
          LullangObjectManager.createOrUpdate('player', 'PLAYER', px, py, this.tileSize - 2, this.tileSize - 2, '#5fd097');
        }
      }
    }
  }
  tileCountSolid() { return this.rows.join('').split('').filter(c => c === '#').length; }
  render(ctx, camera) {
    for (let ry = 0; ry < this.rows.length; ry++) {
      const row = this.rows[ry];
      for (let rx = 0; rx < row.length; rx++) {
        if (row[rx] !== '#') continue;
        ctx.fillStyle = '#2d2d30';
        ctx.fillRect(rx * this.tileSize - camera.x, ry * this.tileSize - camera.y, this.tileSize, this.tileSize);
